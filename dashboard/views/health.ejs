<!DOCTYPE html>
<html lang="en" data-theme="dark">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>Bot Health — Owner Dashboard</title>
  <link rel="stylesheet" href="/style.css">
  <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.5.0/css/all.min.css" crossorigin="anonymous">
</head>
<body>
<div <% if (isOwnerView) { %>class="server-picker owner-dashboard-shell"<% } else { %>class="app-layout"<% } %>>
  <% if (isOwnerView) { %>
  <nav class="landing-nav">
    <div class="container">
      <a href="/dashboard" class="landing-nav-brand">
        <div class="landing-nav-brand-icon"><i class="fas fa-crown" style="color:white;font-size:16px"></i></div>
        Bot Owner
      </a>
      <div class="landing-nav-links">
        <a href="/dashboard/owner" class="btn btn-secondary btn-sm"><i class="fas fa-cog"></i> Settings</a>
        <button class="icon-btn" id="themeToggle" title="Toggle theme"><i class="fas fa-moon"></i></button>
        <div class="topbar-user">
          <img src="https://cdn.discordapp.com/avatars/<%= user.id %>/<%= user.avatar %>.png" alt="Avatar" onerror="this.src='https://cdn.discordapp.com/embed/avatars/0.png'">
          <span class="topbar-user-name"><%= user.username %></span>
        </div>
        <a href="/logout" class="btn btn-secondary btn-sm"><i class="fas fa-sign-out-alt"></i> Logout</a>
      </div>
    </div>
  </nav>
  <main class="server-picker-content">
  <% } else { %>
  <%- include('partials/dashboard-sidebar', { guild, currentPath }) %>

  <div class="main-wrapper">
    <%- include('partials/dashboard-topbar', { guild, user, topbarTitle: 'Bot Health' }) %>

    <main class="content">
  <% } %>
      <div class="page-header">
        <h1><i class="fas fa-heart-pulse" style="color:var(--brand);margin-right:8px"></i>Bot Health</h1>
        <p><% if (isOwnerView) { %>Live status and recent dashboard activity for the bot<% } else { %>Live status and recent admin activity for <strong><%= guild.name %></strong><% } %></p>
      </div>

      <div class="stats-row">
        <div class="stat-card"><div class="stat-card-header"><span class="stat-card-label">Status</span><div class="stat-card-icon green"><i class="fas fa-signal"></i></div></div><div class="stat-card-value"><%= health.status %></div><div class="stat-card-change">Bot heartbeat</div></div>
        <div class="stat-card"><div class="stat-card-header"><span class="stat-card-label">Ping</span><div class="stat-card-icon blue"><i class="fas fa-wifi"></i></div></div><div class="stat-card-value"><%= health.ping %>ms</div><div class="stat-card-change">Discord gateway</div></div>
        <div class="stat-card"><div class="stat-card-header"><span class="stat-card-label">Heap Memory</span><div class="stat-card-icon purple"><i class="fas fa-memory"></i></div></div><div class="stat-card-value"><%= health.memoryMB %> MB</div><div class="stat-card-change">Used by process</div></div>
        <div class="stat-card"><div class="stat-card-header"><span class="stat-card-label">Uptime</span><div class="stat-card-icon yellow"><i class="fas fa-clock"></i></div></div><div class="stat-card-value"><%= Math.floor(health.uptime / 3600) %>h</div><div class="stat-card-change"><%= Math.floor((health.uptime % 3600) / 60) %>m online</div></div>
      </div>

      <div class="card">
        <div class="card-header"><div><div class="card-title"><i class="fas fa-server"></i> Runtime Overview</div><div class="card-subtitle">Core process metrics</div></div></div>
        <div class="table-wrapper">
          <table>
            <tbody>
              <tr><th>Total Servers</th><td><%= health.guilds %></td></tr>
              <tr><th>Cached Users</th><td><%= health.users %></td></tr>
              <tr><th>Heap Memory</th><td><%= health.memoryMB %> MB</td></tr>
              <tr><th>RSS Memory</th><td><%= health.rssMB %> MB</td></tr>
              <tr><th>CPU Time</th><td><%= health.cpuLoad %> ms</td></tr>
            </tbody>
          </table>
        </div>
      </div>

      <div class="card">
        <div class="card-header"><div><div class="card-title"><i class="fas fa-scroll"></i> Recent Dashboard Activity</div><div class="card-subtitle">Latest actions performed from the web dashboard</div></div></div>
        <div class="table-wrapper">
          <table>
            <thead><tr><th>Time</th><th>User</th><th>Action</th><th>Details</th></tr></thead>
            <tbody>
              <% if (auditLogs.length > 0) { %>
                <% auditLogs.forEach(entry => { %>
                  <tr>
                    <td><%= new Date(entry.timestamp).toLocaleString() %></td>
                    <td><%= entry.username || 'Unknown' %></td>
                    <td><strong><%= entry.action %></strong></td>
                    <td><%= JSON.stringify(entry.details || {}) %></td>
                  </tr>
                <% }) %>
              <% } else { %>
                <tr><td colspan="4" class="table-empty"><i class="fas fa-scroll"></i> No recent dashboard activity</td></tr>
              <% } %>
            </tbody>
          </table>
        </div>
      </div>
    </main>
  <% if (isOwnerView) { %>
  </main>
  <% } else { %>
  </div>
</div>
  <% } %>
</div>

<%- include('partials/dashboard-common-scripts') %>
<script>
</script>
</body>
</html>