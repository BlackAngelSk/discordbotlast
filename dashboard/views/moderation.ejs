<!DOCTYPE html>
<html lang="en" data-theme="dark">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title><%= guild.name %> — Moderation</title>
  <link rel="stylesheet" href="/style.css">
  <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.5.0/css/all.min.css" crossorigin="anonymous">
</head>
<body>
<div class="app-layout">
  <%- include('partials/dashboard-sidebar', { guild, currentPath }) %>
  <div class="main-wrapper">
    <%- include('partials/dashboard-topbar', { guild, user, topbarTitle: 'Moderation' }) %>
    <main class="content">
      <div class="page-header">
        <h1><i class="fas fa-shield-halved" style="color:var(--brand);margin-right:8px"></i>Moderation Panel</h1>
        <p>Manage warnings, bans and enforcement for <strong><%= guild.name %></strong></p>
      </div>
      <div class="stats-row">
        <div class="stat-card">
          <div class="stat-card-header"><span class="stat-card-label">Warnings</span><div class="stat-card-icon yellow"><i class="fas fa-triangle-exclamation"></i></div></div>
          <div class="stat-card-value"><%= warnings ? warnings.length : 0 %></div>
          <div class="stat-card-change"><i class="fas fa-scroll"></i> Active warnings</div>
        </div>
        <div class="stat-card">
          <div class="stat-card-header"><span class="stat-card-label">Bans</span><div class="stat-card-icon red"><i class="fas fa-ban"></i></div></div>
          <div class="stat-card-value"><%= bans ? bans.length : 0 %></div>
          <div class="stat-card-change"><i class="fas fa-gavel"></i> Banned users</div>
        </div>
        <div class="stat-card">
          <div class="stat-card-header"><span class="stat-card-label">Kicks</span><div class="stat-card-icon orange"><i class="fas fa-person-walking-arrow-right"></i></div></div>
          <div class="stat-card-value"><%= kicks ? kicks.length : 0 %></div>
          <div class="stat-card-change"><i class="fas fa-door-open"></i> Kick records</div>
        </div>
        <div class="stat-card">
          <div class="stat-card-header"><span class="stat-card-label">Timeouts</span><div class="stat-card-icon purple"><i class="fas fa-clock"></i></div></div>
          <div class="stat-card-value"><%= timeouts ? timeouts.length : 0 %></div>
          <div class="stat-card-change"><i class="fas fa-hourglass"></i> Timeout records</div>
        </div>
      </div>
      <div class="card" style="margin-bottom:20px">
        <div class="card-header">
          <div><div class="card-title"><i class="fas fa-plus"></i> Add Warning</div><div class="card-subtitle">Manually warn a user</div></div>
        </div>
        <form id="addWarningForm">
          <div class="form-row">
            <div class="form-group">
              <label class="form-label">User ID</label>
              <input type="text" class="form-control" name="userId" placeholder="123456789012345678" required>
            </div>
            <div class="form-group">
              <label class="form-label">Reason</label>
              <input type="text" class="form-control" name="reason" placeholder="Enter warning reason" required>
            </div>
          </div>
          <button type="submit" class="btn btn-primary"><i class="fas fa-triangle-exclamation"></i> Add Warning</button>
        </form>
      </div>
      <div class="card">
        <div class="card-header"><div class="card-title"><i class="fas fa-gavel"></i> Moderation Records</div></div>
        <div class="tabs">
          <button class="tab-btn active" data-tab="warnings"><i class="fas fa-triangle-exclamation"></i> Warnings</button>
          <button class="tab-btn" data-tab="bans"><i class="fas fa-ban"></i> Bans</button>
          <button class="tab-btn" data-tab="kicks"><i class="fas fa-person-walking-arrow-right"></i> Kicks</button>
          <button class="tab-btn" data-tab="timeouts"><i class="fas fa-clock"></i> Timeouts</button>
        </div>
        <div class="tab-panel active" id="tab-warnings">
          <div style="margin-bottom:12px"><input type="text" class="form-control" placeholder="Search warnings..." oninput="filterTable('warningsTbl', this.value)" style="max-width:360px"></div>
          <div class="table-wrapper">
            <table id="warningsTbl">
              <thead><tr><th>User</th><th>User ID</th><th>Reason</th><th>Moderator</th><th>Date</th><th>Actions</th></tr></thead>
              <tbody>
                <% if (warnings && warnings.length > 0) { %>
                  <% warnings.forEach(w => { %>
                    <tr>
                      <td><span class="badge badge-warning"><i class="fas fa-triangle-exclamation"></i></span> <%= w.username || 'Unknown' %></td>
                      <td><code><%= w.userId %></code></td>
                      <td><%= w.reason %></td>
                      <td><%= w.moderator || 'System' %></td>
                      <td><%= new Date(w.timestamp).toLocaleDateString() %></td>
                      <td><button class="btn btn-danger btn-sm" onclick="removeWarning('<%= w.userId %>', '<%= w.id %>')"><i class="fas fa-trash"></i></button></td>
                    </tr>
                  <% }); %>
                <% } else { %>
                  <tr><td colspan="6" class="table-empty"><i class="fas fa-triangle-exclamation"></i> No warnings found</td></tr>
                <% } %>
              </tbody>
            </table>
          </div>
        </div>
        <div class="tab-panel" id="tab-bans">
          <div style="margin-bottom:12px"><input type="text" class="form-control" placeholder="Search bans..." oninput="filterTable('bansTbl', this.value)" style="max-width:360px"></div>
          <div class="table-wrapper">
            <table id="bansTbl">
              <thead><tr><th>User</th><th>User ID</th><th>Reason</th><th>Moderator</th><th>Date</th><th>Actions</th></tr></thead>
              <tbody>
                <% if (bans && bans.length > 0) { %>
                  <% bans.forEach(b => { %>
                    <tr>
                      <td><span class="badge badge-danger"><i class="fas fa-ban"></i></span> <%= b.user.username %>#<%= b.user.discriminator %></td>
                      <td><code><%= b.user.id %></code></td>
                      <td><%= b.reason || 'No reason' %></td>
                      <td><%= b.moderator || 'Unknown' %></td>
                      <td><%= new Date(b.timestamp || Date.now()).toLocaleDateString() %></td>
                      <td><button class="btn btn-success btn-sm" onclick="unbanUser('<%= b.user.id %>')"><i class="fas fa-rotate-left"></i> Unban</button></td>
                    </tr>
                  <% }); %>
                <% } else { %>
                  <tr><td colspan="6" class="table-empty"><i class="fas fa-ban"></i> No bans found</td></tr>
                <% } %>
              </tbody>
            </table>
          </div>
        </div>
        <div class="tab-panel" id="tab-kicks">
          <div class="table-wrapper">
            <table>
              <thead><tr><th>User</th><th>Reason</th><th>Moderator</th><th>Date</th></tr></thead>
              <tbody>
                <% if (kicks && kicks.length > 0) { %>
                  <% kicks.forEach(k => { %>
                    <tr>
                      <td><span class="badge badge-warning"><i class="fas fa-person-walking-arrow-right"></i></span> <%= k.username %></td>
                      <td><%= k.reason %></td>
                      <td><%= k.moderator %></td>
                      <td><%= new Date(k.timestamp).toLocaleDateString() %></td>
                    </tr>
                  <% }); %>
                <% } else { %>
                  <tr><td colspan="4" class="table-empty"><i class="fas fa-person-walking-arrow-right"></i> No kicks recorded</td></tr>
                <% } %>
              </tbody>
            </table>
          </div>
        </div>
        <div class="tab-panel" id="tab-timeouts">
          <div class="table-wrapper">
            <table>
              <thead><tr><th>User</th><th>Duration</th><th>Reason</th><th>Moderator</th><th>Date</th></tr></thead>
              <tbody>
                <% if (timeouts && timeouts.length > 0) { %>
                  <% timeouts.forEach(t => { %>
                    <tr>
                      <td><span class="badge badge-info"><i class="fas fa-clock"></i></span> <%= t.username %></td>
                      <td><%= t.duration %> min</td>
                      <td><%= t.reason %></td>
                      <td><%= t.moderator %></td>
                      <td><%= new Date(t.timestamp).toLocaleDateString() %></td>
                    </tr>
                  <% }); %>
                <% } else { %>
                  <tr><td colspan="5" class="table-empty"><i class="fas fa-clock"></i> No timeouts recorded</td></tr>
                <% } %>
              </tbody>
            </table>
          </div>
        </div>
      </div>
    </main>
  </div>
</div>
<div class="toast-container" id="toasts"></div>
<%- include('partials/dashboard-common-scripts') %>
<script>
const guildId = '<%= guild.id %>';
function toast(msg, type = 'success') {
  const c = document.getElementById('toasts');
  const t = document.createElement('div');
  t.className = `toast toast-${type}`;
  const icons = { success: 'fa-check-circle', error: 'fa-xmark-circle', info: 'fa-circle-info', warning: 'fa-triangle-exclamation' };
  t.innerHTML = `<i class="fas ${icons[type] || 'fa-check-circle'}"></i> ${msg}`;
  c.appendChild(t);
  setTimeout(() => t.remove(), 3200);
}
document.querySelectorAll('.tab-btn').forEach(btn => {
  btn.addEventListener('click', () => {
    document.querySelectorAll('.tab-btn').forEach(b => b.classList.remove('active'));
    document.querySelectorAll('.tab-panel').forEach(p => p.classList.remove('active'));
    btn.classList.add('active');
    document.getElementById('tab-' + btn.dataset.tab).classList.add('active');
  });
});
function filterTable(tableId, q) {
  const tbl = document.getElementById(tableId);
  if (!tbl) return;
  Array.from(tbl.querySelectorAll('tbody tr')).forEach(r => {
    r.style.display = r.textContent.toLowerCase().includes(q.toLowerCase()) ? '' : 'none';
  });
}
document.getElementById('addWarningForm').addEventListener('submit', async e => {
  e.preventDefault();
  const data = Object.fromEntries(new FormData(e.target));
  try {
    const r = await fetch(`/api/${guildId}/moderation/warnings`, { method: 'POST', headers: { 'Content-Type': 'application/json' }, body: JSON.stringify(data) });
    if (r.ok) { toast('Warning added!', 'success'); setTimeout(() => location.reload(), 1200); }
    else toast('Failed to add warning', 'error');
  } catch(err) { toast('Error: ' + err.message, 'error'); }
});
async function removeWarning(userId, warningId) {
  if (!confirm('Remove this warning?')) return;
  try {
    const r = await fetch(`/api/${guildId}/moderation/warnings/${userId}/${warningId}`, { method: 'DELETE' });
    if (r.ok) { toast('Warning removed!', 'success'); setTimeout(() => location.reload(), 1200); }
    else toast('Failed to remove', 'error');
  } catch(err) { toast('Error: ' + err.message, 'error'); }
}
async function unbanUser(userId) {
  if (!confirm('Unban this user?')) return;
  try {
    const r = await fetch(`/api/${guildId}/moderation/unban`, { method: 'POST', headers: { 'Content-Type': 'application/json' }, body: JSON.stringify({ userId }) });
    if (r.ok) { toast('User unbanned!', 'success'); setTimeout(() => location.reload(), 1200); }
    else toast('Failed to unban', 'error');
  } catch(err) { toast('Error: ' + err.message, 'error'); }
}
</script>
</body>
</html>