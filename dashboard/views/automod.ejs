<!DOCTYPE html>
<html lang="en" data-theme="dark">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title><%= guild.name %> — Auto-Mod</title>
  <link rel="stylesheet" href="/style.css">
  <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.5.0/css/all.min.css" crossorigin="anonymous">
</head>
<body>
<div class="app-layout">
  <%- include('partials/dashboard-sidebar', { guild, currentPath }) %>
  <div class="main-wrapper">
    <%- include('partials/dashboard-topbar', { guild, user, topbarTitle: 'Auto-Moderation' }) %>
    <main class="content">
      <div class="page-header">
        <h1><i class="fas fa-robot" style="color:var(--brand);margin-right:8px"></i>Auto-Moderation</h1>
        <p>Configure automatic enforcement rules for <strong><%= guild.name %></strong></p>
      </div>
      <form id="automodForm">
        <div class="card">
          <div class="card-header"><div><div class="card-title"><i class="fas fa-sliders"></i> Moderation Rules</div><div class="card-subtitle">Automatically enforce server rules</div></div></div>
          <div class="toggle-group">
            <div class="toggle-info"><h4>Enable Auto-Moderation</h4><p>Master switch — turns all auto-mod features on/off</p></div>
            <label class="toggle-switch"><input type="checkbox" name="enabled" <%= settings.enabled ? 'checked' : '' %>><span class="toggle-slider"></span></label>
          </div>
          <div class="toggle-group">
            <div class="toggle-info"><h4>Anti-Invite Links</h4><p>Delete messages containing Discord invite links (discord.gg/...)</p></div>
            <label class="toggle-switch"><input type="checkbox" name="antiInvite" <%= settings.antiInvite ? 'checked' : '' %>><span class="toggle-slider"></span></label>
          </div>
          <div class="toggle-group">
            <div class="toggle-info"><h4>Anti-Spam</h4><p>Timeout users who send 5+ messages within 5 seconds</p></div>
            <label class="toggle-switch"><input type="checkbox" name="antiSpam" <%= settings.antiSpam ? 'checked' : '' %>><span class="toggle-slider"></span></label>
          </div>
          <div class="form-row" style="margin-top:20px">
            <div class="form-group">
              <label class="form-label">Max Mentions per Message</label>
              <input type="number" class="form-control" name="maxMentions" value="<%= settings.maxMentions || 5 %>" min="1" max="50">
              <div class="form-hint">Messages exceeding this will be deleted</div>
            </div>
            <div class="form-group">
              <label class="form-label">Max Emojis per Message</label>
              <input type="number" class="form-control" name="maxEmojis" value="<%= settings.maxEmojis || 10 %>" min="1" max="100">
              <div class="form-hint">Messages exceeding this will be deleted</div>
            </div>
          </div>
          <div class="form-actions">
            <button type="submit" class="btn btn-primary btn-lg"><i class="fas fa-save"></i> Save Settings</button>
          </div>
        </div>
      </form>
      <div class="card">
        <div class="card-header"><div><div class="card-title"><i class="fas fa-filter"></i> Bad Words Filter</div><div class="card-subtitle">Automatically delete messages containing these words</div></div></div>
        <div style="display:flex;gap:10px;margin-bottom:16px">
          <input type="text" class="form-control" id="newBadWord" placeholder="Enter word to blacklist..." style="max-width:320px">
          <button class="btn btn-primary" onclick="addBadWord()"><i class="fas fa-plus"></i> Add Word</button>
        </div>
        <div class="badword-list" id="badwordsList">
          <% if (settings.badWords && settings.badWords.length > 0) { %>
            <% settings.badWords.forEach(word => { %>
              <span class="badword-tag"><%= word %><button onclick="removeBadWord('<%= word %>')"><i class="fas fa-xmark"></i></button></span>
            <% }); %>
          <% } else { %>
            <p style="color:var(--text-2);font-size:14px"><i class="fas fa-filter"></i> No blacklisted words yet</p>
          <% } %>
        </div>
      </div>
    </main>
  </div>
</div>
<div class="toast-container" id="toasts"></div>
<%- include('partials/dashboard-common-scripts') %>
<script>
const guildId = '<%= guild.id %>';
function toast(msg, type = 'success') {
  const c = document.getElementById('toasts');
  const t = document.createElement('div');
  t.className = `toast toast-${type}`;
  const icons = { success: 'fa-check-circle', error: 'fa-xmark-circle' };
  t.innerHTML = `<i class="fas ${icons[type] || 'fa-check-circle'}"></i> ${msg}`;
  c.appendChild(t);
  setTimeout(() => t.remove(), 3200);
}
document.getElementById('automodForm').addEventListener('submit', async e => {
  e.preventDefault();
  const btn = e.submitter;
  const orig = btn.innerHTML;
  btn.innerHTML = '<span class="spinner"></span> Saving...';
  btn.disabled = true;
  const fd = new FormData(e.target);
  const data = {
    enabled: fd.get('enabled') === 'on',
    antiInvite: fd.get('antiInvite') === 'on',
    antiSpam: fd.get('antiSpam') === 'on',
    maxMentions: parseInt(fd.get('maxMentions')),
    maxEmojis: parseInt(fd.get('maxEmojis'))
  };
  try {
    const r = await fetch(`/api/${guildId}/automod/settings`, { method: 'POST', headers: { 'Content-Type': 'application/json' }, body: JSON.stringify(data) });
    if (r.ok) toast('Settings saved!', 'success');
    else toast('Failed to save', 'error');
  } catch(err) { toast('Error: ' + err.message, 'error'); }
  finally { btn.innerHTML = orig; btn.disabled = false; }
});
async function addBadWord() {
  const word = document.getElementById('newBadWord').value.trim();
  if (!word) { toast('Enter a word first', 'error'); return; }
  try {
    const r = await fetch(`/api/${guildId}/automod/badwords`, { method: 'POST', headers: { 'Content-Type': 'application/json' }, body: JSON.stringify({ word }) });
    if (r.ok) { toast(`"${word}" added to blacklist`, 'success'); setTimeout(() => location.reload(), 900); }
    else toast('Failed to add word', 'error');
  } catch(err) { toast('Error: ' + err.message, 'error'); }
}
async function removeBadWord(word) {
  try {
    const r = await fetch(`/api/${guildId}/automod/badwords/remove`, { method: 'POST', headers: { 'Content-Type': 'application/json' }, body: JSON.stringify({ word }) });
    if (r.ok) { toast(`"${word}" removed`, 'success'); setTimeout(() => location.reload(), 900); }
    else toast('Failed to remove', 'error');
  } catch(err) { toast('Error: ' + err.message, 'error'); }
}
</script>
</body>
</html>