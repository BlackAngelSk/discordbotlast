<!DOCTYPE html>
<html lang="en" data-theme="dark">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title><%= guild.name %> — Telegram Sync</title>
    <link rel="stylesheet" href="/style.css">
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.5.0/css/all.min.css" crossorigin="anonymous">
</head>
<body>
<div class="app-layout">
    <%- include('partials/dashboard-sidebar', { guild, currentPath }) %>

    <div class="main-wrapper">
        <%- include('partials/dashboard-topbar', { guild, user, topbarTitle: 'Telegram Sync' }) %>

        <main class="content">
            <div class="page-header">
                <h1><i class="fab fa-telegram" style="color:var(--brand);margin-right:8px"></i>Telegram Message Sync</h1>
                <p>Bridge one Discord channel with one Telegram chat for <strong><%= guild.name %></strong>.</p>
            </div>

            <div class="stats-row">
                <div class="stat-card">
                    <div class="stat-card-header"><span class="stat-card-label">Bridge Status</span><div class="stat-card-icon <%= config?.enabled ? 'green' : 'yellow' %>"><i class="fas fa-link"></i></div></div>
                    <div class="stat-card-value"><%= config?.enabled ? 'On' : 'Off' %></div>
                    <div class="stat-card-change"><i class="fas fa-repeat"></i> Two-way relay</div>
                </div>
                <div class="stat-card">
                    <div class="stat-card-header"><span class="stat-card-label">Discord Channel</span><div class="stat-card-icon blue"><i class="fas fa-hashtag"></i></div></div>
                    <div class="stat-card-value" style="font-size:1rem"><%= config?.discordChannelId ? `#${guild.channels.cache.get(config.discordChannelId)?.name || config.discordChannelId}` : 'Not set' %></div>
                    <div class="stat-card-change"><i class="fas fa-message"></i> Source and destination</div>
                </div>
                <div class="stat-card">
                    <div class="stat-card-header"><span class="stat-card-label">Telegram Chat ID</span><div class="stat-card-icon purple"><i class="fas fa-paper-plane"></i></div></div>
                    <div class="stat-card-value" style="font-size:1rem"><%= config?.telegramChatId || 'Not set' %></div>
                    <div class="stat-card-change"><i class="fas fa-keyboard"></i> Numeric chat ID</div>
                </div>
                <div class="stat-card">
                    <div class="stat-card-header"><span class="stat-card-label">Bot Token</span><div class="stat-card-icon <%= envStatus?.hasToken ? 'green' : 'orange' %>"><i class="fas fa-key"></i></div></div>
                    <div class="stat-card-value"><%= envStatus?.hasToken ? 'Ready' : 'Missing' %></div>
                    <div class="stat-card-change">Set TELEGRAM_BOT_TOKEN in .env</div>
                </div>
            </div>

            <% if (!envStatus?.hasToken) { %>
                <div class="card" style="border-color:rgba(250,204,21,.35);margin-bottom:20px">
                    <div class="card-header">
                        <div>
                            <div class="card-title"><i class="fas fa-triangle-exclamation"></i> Telegram Token Required</div>
                            <div class="card-subtitle">Add <strong>TELEGRAM_BOT_TOKEN</strong> to your bot environment and restart the bot before enabling sync.</div>
                        </div>
                    </div>
                </div>
            <% } %>

            <div class="card" style="margin-bottom:20px">
                <div class="card-header">
                    <div>
                        <div class="card-title"><i class="fas fa-sliders"></i> Bridge Setup</div>
                        <div class="card-subtitle">Use @RawDataBot in Telegram to get your chat ID (groups usually start with -100).</div>
                    </div>
                </div>

                <form id="telegramSyncForm">
                    <div class="form-row">
                        <div class="form-group" style="width:100%">
                            <label class="checkbox-wrap" style="display:flex;align-items:center;gap:10px;cursor:pointer;margin-bottom:0">
                                <input type="checkbox" id="telegramEnabled" name="enabled" <%= config?.enabled ? 'checked' : '' %>>
                                <span>Enable Discord ↔ Telegram sync</span>
                            </label>
                            <div class="form-hint">When disabled, your settings stay saved but no messages are relayed.</div>
                        </div>
                    </div>

                    <div class="form-row">
                        <div class="form-group">
                            <label class="form-label">Discord Channel</label>
                            <select name="discordChannelId" class="form-control">
                                <option value="">Select channel</option>
                                <% channels.forEach(channel => { %>
                                    <option value="<%= channel.id %>" <%= config?.discordChannelId === channel.id ? 'selected' : '' %>>#<%= channel.name %></option>
                                <% }) %>
                            </select>
                            <div class="form-hint">Only messages in this channel are mirrored to Telegram.</div>
                        </div>
                        <div class="form-group">
                            <label class="form-label">Telegram Chat ID</label>
                            <input type="text" name="telegramChatId" class="form-control" placeholder="-1001234567890" value="<%= config?.telegramChatId || '' %>">
                            <div class="form-hint">Numeric ID (e.g. <code>-1001234567890</code>) or public username (e.g. <code>@mychannel</code>). Use @RawDataBot in Telegram to find an ID.</div>
                        </div>
                    </div>

                    <div class="form-row" style="gap:16px">
                        <label class="checkbox-wrap" style="display:flex;align-items:center;gap:10px;cursor:pointer">
                            <input type="checkbox" name="syncDiscordToTelegram" <%= config?.syncDiscordToTelegram === false ? '' : 'checked' %>>
                            <span>Sync Discord → Telegram</span>
                        </label>
                        <label class="checkbox-wrap" style="display:flex;align-items:center;gap:10px;cursor:pointer">
                            <input type="checkbox" name="syncTelegramToDiscord" <%= config?.syncTelegramToDiscord === false ? '' : 'checked' %>>
                            <span>Sync Telegram → Discord</span>
                        </label>
                        <label class="checkbox-wrap" style="display:flex;align-items:center;gap:10px;cursor:pointer">
                            <input type="checkbox" name="includeAttachments" <%= config?.includeAttachments === false ? '' : 'checked' %>>
                            <span>Include Discord attachment URLs</span>
                        </label>
                    </div>

                    <div class="form-actions" style="justify-content:flex-start;margin-top:20px">
                        <button type="submit" class="btn btn-primary"><i class="fas fa-save"></i> Save Telegram Sync</button>
                        <button type="button" class="btn btn-secondary" id="testDiscordToTelegramBtn"><i class="fas fa-right-long"></i> Test Discord → Telegram</button>
                        <button type="button" class="btn btn-secondary" id="testTelegramToDiscordBtn"><i class="fas fa-left-long"></i> Test Telegram → Discord</button>
                        <button type="button" class="btn btn-danger" id="disableTelegramSyncBtn"><i class="fas fa-unlink"></i> Disable Sync</button>
                    </div>
                </form>
            </div>

            <div class="card">
                <div class="card-header">
                    <div>
                        <div class="card-title"><i class="fas fa-circle-info"></i> Notes</div>
                        <div class="card-subtitle">Telegram bots can only read chats where they were added.</div>
                    </div>
                </div>
                <ul style="margin:0;padding-left:18px;color:var(--text-secondary);line-height:1.7">
                    <li>Invite your Telegram bot to the target chat and send at least one message there.</li>
                    <li>Discord bot messages are not re-forwarded, which prevents sync loops.</li>
                    <li>Telegram edits are not mirrored yet; only new messages are forwarded.</li>
                </ul>
            </div>
        </main>
    </div>
</div>

<%- include('partials/dashboard-common-scripts') %>
<script>
const guildId = '<%= guild.id %>';
const form = document.getElementById('telegramSyncForm');
const saveButton = form.querySelector('button[type="submit"]');
const testD2TButton = document.getElementById('testDiscordToTelegramBtn');
const testT2DButton = document.getElementById('testTelegramToDiscordBtn');
const disableButton = document.getElementById('disableTelegramSyncBtn');

async function postJson(url, body, method = 'POST') {
    const response = await fetch(url, {
        method,
        headers: { 'Content-Type': 'application/json' },
        body: body ? JSON.stringify(body) : undefined
    });

    const result = await response.json().catch(() => ({ success: false, error: 'Invalid server response' }));
    if (!response.ok || !result.success) {
        throw new Error(result.error || 'Request failed');
    }

    return result;
}

form.addEventListener('submit', async (event) => {
    event.preventDefault();
    const original = saveButton.innerHTML;
    saveButton.disabled = true;
    saveButton.innerHTML = '<span class="spinner"></span> Saving...';

    try {
        const fd = new FormData(form);
        const payload = {
            enabled: fd.get('enabled') === 'on',
            discordChannelId: String(fd.get('discordChannelId') || '').trim(),
            telegramChatId: String(fd.get('telegramChatId') || '').trim(),
            syncDiscordToTelegram: fd.get('syncDiscordToTelegram') === 'on',
            syncTelegramToDiscord: fd.get('syncTelegramToDiscord') === 'on',
            includeAttachments: fd.get('includeAttachments') === 'on'
        };

        await postJson(`/api/telegram-sync/${guildId}`, payload, 'POST');
        dashboardUI.showToast('Telegram sync settings saved.', 'success');
        setTimeout(() => location.reload(), 650);
    } catch (error) {
        dashboardUI.showToast(error.message || 'Failed to save Telegram sync settings.', 'error');
    } finally {
        saveButton.disabled = false;
        saveButton.innerHTML = original;
    }
});

testD2TButton.addEventListener('click', async () => {
    const original = testD2TButton.innerHTML;
    testD2TButton.disabled = true;
    testD2TButton.innerHTML = '<span class="spinner"></span> Testing...';

    try {
        const result = await postJson(`/api/telegram-sync/${guildId}/test`, { direction: 'discordToTelegram' }, 'POST');
        dashboardUI.showToast(result.message || 'Discord -> Telegram test sent.', 'success');
    } catch (error) {
        dashboardUI.showToast(error.message || 'Test failed.', 'error');
    } finally {
        testD2TButton.disabled = false;
        testD2TButton.innerHTML = original;
    }
});

testT2DButton.addEventListener('click', async () => {
    const original = testT2DButton.innerHTML;
    testT2DButton.disabled = true;
    testT2DButton.innerHTML = '<span class="spinner"></span> Testing...';

    try {
        const result = await postJson(`/api/telegram-sync/${guildId}/test`, { direction: 'telegramToDiscord' }, 'POST');
        dashboardUI.showToast(result.message || 'Telegram -> Discord test sent.', 'success');
    } catch (error) {
        dashboardUI.showToast(error.message || 'Test failed.', 'error');
    } finally {
        testT2DButton.disabled = false;
        testT2DButton.innerHTML = original;
    }
});

disableButton.addEventListener('click', async () => {
    if (!confirm('Disable Telegram sync for this server?')) return;

    const original = disableButton.innerHTML;
    disableButton.disabled = true;
    disableButton.innerHTML = '<span class="spinner"></span> Disabling...';

    try {
        await postJson(`/api/telegram-sync/${guildId}`, null, 'DELETE');
        dashboardUI.showToast('Telegram sync disabled.', 'success');
        setTimeout(() => location.reload(), 650);
    } catch (error) {
        dashboardUI.showToast(error.message || 'Failed to disable Telegram sync.', 'error');
    } finally {
        disableButton.disabled = false;
        disableButton.innerHTML = original;
    }
});
</script>
</body>
</html>
