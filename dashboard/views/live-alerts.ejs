<!DOCTYPE html>
<html lang="en" data-theme="dark">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title><%= guild.name %> — Live Alerts</title>
    <link rel="stylesheet" href="/style.css">
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.5.0/css/all.min.css" crossorigin="anonymous">
</head>
<body>
<div class="app-layout">
    <aside class="sidebar" id="sidebar">
        <div class="sidebar-header">
            <a href="/dashboard" class="sidebar-back"><i class="fas fa-arrow-left"></i> All Servers</a>
            <div class="sidebar-guild">
                <% if (guild.icon) { %>
                    <img class="sidebar-guild-icon" src="https://cdn.discordapp.com/icons/<%= guild.id %>/<%= guild.icon %>.png" alt="<%= guild.name %>">
                <% } else { %>
                    <div class="sidebar-guild-icon-default"><%= guild.name.charAt(0) %></div>
                <% } %>
                <div class="sidebar-guild-info"><h3><%= guild.name %></h3><span><%= guild.memberCount %> members</span></div>
            </div>
        </div>
        <nav class="sidebar-nav">
            <div class="sidebar-section-label">Server</div>
            <a href="/dashboard/<%= guild.id %>" class="sidebar-link"><i class="fas fa-cog"></i> Settings</a>
            <a href="/dashboard/<%= guild.id %>/economy" class="sidebar-link"><i class="fas fa-coins"></i> Economy</a>
            <a href="/dashboard/<%= guild.id %>/shop" class="sidebar-link"><i class="fas fa-store"></i> Shop</a>
            <a href="/dashboard/<%= guild.id %>/commands" class="sidebar-link"><i class="fas fa-terminal"></i> Commands</a>
            <a href="/dashboard/<%= guild.id %>/live-alerts" class="sidebar-link active"><i class="fas fa-satellite-dish"></i> Live Alerts</a>
            <div class="sidebar-section-label">Moderation</div>
            <a href="/dashboard/<%= guild.id %>/moderation" class="sidebar-link"><i class="fas fa-shield-halved"></i> Moderation</a>
            <a href="/dashboard/<%= guild.id %>/automod" class="sidebar-link"><i class="fas fa-robot"></i> Auto-Mod</a>
            <div class="sidebar-section-label">Stats</div>
            <a href="/dashboard/<%= guild.id %>/analytics" class="sidebar-link"><i class="fas fa-chart-line"></i> Analytics</a>
            <a href="/global-leaderboard" class="sidebar-link"><i class="fas fa-globe"></i> Global Leaderboard</a>
        </nav>
        <div class="sidebar-footer"><a href="/logout" class="sidebar-link danger"><i class="fas fa-sign-out-alt"></i> Logout</a></div>
    </aside>
    <div class="sidebar-overlay" id="sidebarOverlay"></div>

    <div class="main-wrapper">
        <header class="topbar">
            <div class="topbar-left">
                <button class="mobile-menu-btn" id="mobileMenuBtn"><i class="fas fa-bars"></i></button>
                <div><div class="topbar-title">Live Alerts</div><div class="topbar-subtitle"><%= guild.name %></div></div>
            </div>
            <div class="topbar-right">
                <button class="icon-btn" id="themeToggle"><i class="fas fa-moon"></i></button>
                <div class="topbar-user">
                    <img src="https://cdn.discordapp.com/avatars/<%= user.id %>/<%= user.avatar %>.png" alt="Avatar" onerror="this.src='https://cdn.discordapp.com/embed/avatars/0.png'">
                    <span class="topbar-user-name"><%= user.username %></span>
                </div>
            </div>
        </header>

        <main class="content">
            <div class="page-header">
                <h1><i class="fas fa-satellite-dish" style="color:var(--brand);margin-right:8px"></i>Live Stream Alerts</h1>
                <p>Manage Twitch and YouTube notifications for <strong><%= guild.name %></strong></p>
            </div>

            <div class="stats-row">
                <div class="stat-card">
                    <div class="stat-card-header"><span class="stat-card-label">Twitch Alerts</span><div class="stat-card-icon purple"><i class="fab fa-twitch"></i></div></div>
                    <div class="stat-card-value"><%= alerts.twitch?.length || 0 %></div>
                    <div class="stat-card-change"><i class="fas fa-bell"></i> Active watches</div>
                </div>
                <div class="stat-card">
                    <div class="stat-card-header"><span class="stat-card-label">YouTube Alerts</span><div class="stat-card-icon red"><i class="fab fa-youtube"></i></div></div>
                    <div class="stat-card-value"><%= alerts.youtube?.length || 0 %></div>
                    <div class="stat-card-change"><i class="fas fa-video"></i> Active watches</div>
                </div>
                <div class="stat-card">
                    <div class="stat-card-header"><span class="stat-card-label">Twitch API</span><div class="stat-card-icon <%= envStatus.twitch ? 'green' : 'yellow' %>"><i class="fas fa-plug"></i></div></div>
                    <div class="stat-card-value"><%= envStatus.twitch ? 'Ready' : 'Missing' %></div>
                    <div class="stat-card-change"><i class="fas fa-key"></i> Client credentials</div>
                </div>
                <div class="stat-card">
                    <div class="stat-card-header"><span class="stat-card-label">YouTube API</span><div class="stat-card-icon <%= envStatus.youtube ? 'green' : 'yellow' %>"><i class="fas fa-plug"></i></div></div>
                    <div class="stat-card-value"><%= envStatus.youtube ? 'Ready' : 'Missing' %></div>
                    <div class="stat-card-change"><i class="fas fa-key"></i> API key</div>
                </div>
            </div>

            <% if (!envStatus.twitch || !envStatus.youtube) { %>
                <div class="card" style="border-color:rgba(250,204,21,.35)">
                    <div class="card-header">
                        <div>
                            <div class="card-title"><i class="fas fa-triangle-exclamation"></i> Setup Note</div>
                            <div class="card-subtitle">Alerts save normally, but posting requires the related API keys in the bot environment.</div>
                        </div>
                    </div>
                </div>
            <% } %>

            <div style="display:grid;grid-template-columns:1fr 1fr;gap:20px;margin-bottom:20px">
                <div class="card">
                    <div class="card-header">
                        <div>
                            <div class="card-title"><i class="fab fa-twitch"></i> Add Twitch Alert</div>
                            <div class="card-subtitle">Watch a Twitch username and post when they go live</div>
                        </div>
                    </div>
                    <form class="live-alert-form" data-platform="twitch">
                        <div class="form-group">
                            <label class="form-label">Twitch Username</label>
                            <input type="text" name="identifier" class="form-control" placeholder="streamername" required>
                        </div>
                        <div class="form-group">
                            <label class="form-label">Discord Channel</label>
                            <select name="discordChannelId" class="form-control" required>
                                <option value="">Select channel</option>
                                <% channels.forEach(channel => { %>
                                    <option value="<%= channel.id %>">#<%= channel.name %></option>
                                <% }) %>
                            </select>
                        </div>
                        <div class="form-group">
                            <label class="form-label">Mention Role</label>
                            <select name="roleId" class="form-control">
                                <option value="">No role mention</option>
                                <% roles.forEach(role => { %>
                                    <option value="<%= role.id %>"><%= role.name %></option>
                                <% }) %>
                            </select>
                        </div>
                        <button type="submit" class="btn btn-primary"><i class="fas fa-plus"></i> Add Twitch Alert</button>
                    </form>
                </div>

                <div class="card">
                    <div class="card-header">
                        <div>
                            <div class="card-title"><i class="fab fa-youtube"></i> Add YouTube Alert</div>
                            <div class="card-subtitle">Watch a YouTube channel ID and post when they go live</div>
                        </div>
                    </div>
                    <form class="live-alert-form" data-platform="youtube">
                        <div class="form-group">
                            <label class="form-label">YouTube Channel ID</label>
                            <input type="text" name="identifier" class="form-control" placeholder="UCxxxxxxxxxxxxxxxx" required>
                        </div>
                        <div class="form-group">
                            <label class="form-label">Discord Channel</label>
                            <select name="discordChannelId" class="form-control" required>
                                <option value="">Select channel</option>
                                <% channels.forEach(channel => { %>
                                    <option value="<%= channel.id %>">#<%= channel.name %></option>
                                <% }) %>
                            </select>
                        </div>
                        <div class="form-group">
                            <label class="form-label">Mention Role</label>
                            <select name="roleId" class="form-control">
                                <option value="">No role mention</option>
                                <% roles.forEach(role => { %>
                                    <option value="<%= role.id %>"><%= role.name %></option>
                                <% }) %>
                            </select>
                        </div>
                        <button type="submit" class="btn btn-primary"><i class="fas fa-plus"></i> Add YouTube Alert</button>
                    </form>
                </div>
            </div>

            <div class="card">
                <div class="card-header">
                    <div>
                        <div class="card-title"><i class="fas fa-list"></i> Current Alerts</div>
                        <div class="card-subtitle">Remove or review stream notification rules</div>
                    </div>
                </div>

                <div class="table-wrapper" style="margin-bottom:18px">
                    <table>
                        <thead>
                            <tr><th colspan="5">Twitch</th></tr>
                            <tr><th>Username</th><th>Channel</th><th>Role</th><th>Status</th><th>Action</th></tr>
                        </thead>
                        <tbody>
                            <% if (alerts.twitch && alerts.twitch.length > 0) { %>
                                <% alerts.twitch.forEach(entry => { %>
                                    <tr>
                                        <td><strong><%= entry.username %></strong></td>
                                        <td><%= guild.channels.cache.get(entry.channelId) ? '#' + guild.channels.cache.get(entry.channelId).name : entry.channelId %></td>
                                        <td><%= entry.roleId && guild.roles.cache.get(entry.roleId) ? guild.roles.cache.get(entry.roleId).name : 'None' %></td>
                                        <td><span class="badge <%= entry.lastLive ? 'badge-green' : 'badge-blue' %>"><%= entry.lastLive ? 'Live seen' : 'Watching' %></span></td>
                                        <td><button class="btn btn-danger btn-sm remove-alert-btn" data-platform="twitch" data-identifier="<%= entry.username %>"><i class="fas fa-trash"></i> Remove</button></td>
                                    </tr>
                                <% }) %>
                            <% } else { %>
                                <tr><td colspan="5" class="table-empty"><i class="fab fa-twitch"></i> No Twitch alerts configured</td></tr>
                            <% } %>
                        </tbody>
                    </table>
                </div>

                <div class="table-wrapper">
                    <table>
                        <thead>
                            <tr><th colspan="5">YouTube</th></tr>
                            <tr><th>Channel ID</th><th>Discord Channel</th><th>Role</th><th>Last Video</th><th>Action</th></tr>
                        </thead>
                        <tbody>
                            <% if (alerts.youtube && alerts.youtube.length > 0) { %>
                                <% alerts.youtube.forEach(entry => { %>
                                    <tr>
                                        <td><strong><%= entry.channelId %></strong></td>
                                        <td><%= guild.channels.cache.get(entry.discordChannelId) ? '#' + guild.channels.cache.get(entry.discordChannelId).name : entry.discordChannelId %></td>
                                        <td><%= entry.roleId && guild.roles.cache.get(entry.roleId) ? guild.roles.cache.get(entry.roleId).name : 'None' %></td>
                                        <td><%= entry.lastVideoId || 'Waiting' %></td>
                                        <td><button class="btn btn-danger btn-sm remove-alert-btn" data-platform="youtube" data-identifier="<%= entry.channelId %>"><i class="fas fa-trash"></i> Remove</button></td>
                                    </tr>
                                <% }) %>
                            <% } else { %>
                                <tr><td colspan="5" class="table-empty"><i class="fab fa-youtube"></i> No YouTube alerts configured</td></tr>
                            <% } %>
                        </tbody>
                    </table>
                </div>
            </div>
        </main>
    </div>
</div>

<div class="toast-container" id="toasts"></div>

<script>
const guildId = '<%= guild.id %>';
const saved = localStorage.getItem('theme') || 'dark';
document.documentElement.setAttribute('data-theme', saved);
const themeBtn = document.getElementById('themeToggle');
themeBtn.innerHTML = saved === 'dark' ? '<i class="fas fa-moon"></i>' : '<i class="fas fa-sun"></i>';
themeBtn.addEventListener('click', () => {
    const cur = document.documentElement.getAttribute('data-theme');
    const next = cur === 'dark' ? 'light' : 'dark';
    document.documentElement.setAttribute('data-theme', next);
    localStorage.setItem('theme', next);
    themeBtn.innerHTML = next === 'dark' ? '<i class="fas fa-moon"></i>' : '<i class="fas fa-sun"></i>';
});
const sidebar = document.getElementById('sidebar');
const overlay = document.getElementById('sidebarOverlay');
document.getElementById('mobileMenuBtn').addEventListener('click', () => { sidebar.classList.toggle('open'); overlay.classList.toggle('active'); });
overlay.addEventListener('click', () => { sidebar.classList.remove('open'); overlay.classList.remove('active'); });

function toast(msg, type = 'success') {
    const c = document.getElementById('toasts');
    const t = document.createElement('div');
    t.className = `toast toast-${type}`;
    const icons = { success: 'fa-check-circle', error: 'fa-xmark-circle', info: 'fa-circle-info', warning: 'fa-triangle-exclamation' };
    t.innerHTML = `<i class="fas ${icons[type] || 'fa-check-circle'}"></i> ${msg}`;
    c.appendChild(t);
    setTimeout(() => t.remove(), 3200);
}

document.querySelectorAll('.live-alert-form').forEach(form => {
    form.addEventListener('submit', async (event) => {
        event.preventDefault();
        const platform = form.dataset.platform;
        const submitBtn = form.querySelector('button[type="submit"]');
        const original = submitBtn.innerHTML;
        submitBtn.disabled = true;
        submitBtn.innerHTML = '<span class="spinner"></span> Saving...';

        try {
            const fd = new FormData(form);
            const payload = {
                platform,
                identifier: String(fd.get('identifier') || '').trim(),
                discordChannelId: fd.get('discordChannelId'),
                roleId: fd.get('roleId') || null
            };

            const response = await fetch(`/api/live-alerts/${guildId}`, {
                method: 'POST',
                headers: { 'Content-Type': 'application/json' },
                body: JSON.stringify(payload)
            });

            const result = await response.json();
            if (!response.ok || !result.success) {
                throw new Error(result.error || 'Failed to save live alert');
            }

            toast('Live alert saved successfully');
            setTimeout(() => location.reload(), 700);
        } catch (error) {
            toast(error.message || 'Failed to save live alert', 'error');
        } finally {
            submitBtn.disabled = false;
            submitBtn.innerHTML = original;
        }
    });
});

document.querySelectorAll('.remove-alert-btn').forEach(button => {
    button.addEventListener('click', async () => {
        const platform = button.dataset.platform;
        const identifier = button.dataset.identifier;
        if (!confirm(`Remove this ${platform} alert?`)) return;

        const original = button.innerHTML;
        button.disabled = true;
        button.innerHTML = '<span class="spinner"></span>';

        try {
            const response = await fetch(`/api/live-alerts/${guildId}`, {
                method: 'DELETE',
                headers: { 'Content-Type': 'application/json' },
                body: JSON.stringify({ platform, identifier })
            });

            const result = await response.json();
            if (!response.ok || !result.success) {
                throw new Error(result.error || 'Failed to remove live alert');
            }

            toast('Live alert removed');
            setTimeout(() => location.reload(), 500);
        } catch (error) {
            toast(error.message || 'Failed to remove live alert', 'error');
            button.disabled = false;
            button.innerHTML = original;
        }
    });
});
</script>
</body>
</html>
