<!DOCTYPE html>
<html lang="en" data-theme="dark">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title><%= guild.name %> — Shop</title>
  <link rel="stylesheet" href="/style.css">
  <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.5.0/css/all.min.css" crossorigin="anonymous">
</head>
<body>
<div class="app-layout">
  <aside class="sidebar" id="sidebar">
    <div class="sidebar-header">
      <a href="/dashboard" class="sidebar-back"><i class="fas fa-arrow-left"></i> All Servers</a>
      <div class="sidebar-guild">
        <% if (guild.icon) { %>
          <img class="sidebar-guild-icon" src="https://cdn.discordapp.com/icons/<%= guild.id %>/<%= guild.icon %>.png" alt="<%= guild.name %>">
        <% } else { %>
          <div class="sidebar-guild-icon-default"><%= guild.name.charAt(0) %></div>
        <% } %>
        <div class="sidebar-guild-info"><h3><%= guild.name %></h3><span><%= guild.memberCount %> members</span></div>
      </div>
    </div>
    <nav class="sidebar-nav">
      <div class="sidebar-section-label">Server</div>
      <a href="/dashboard/<%= guild.id %>" class="sidebar-link"><i class="fas fa-cog"></i> Settings</a>
      <a href="/dashboard/<%= guild.id %>/economy" class="sidebar-link"><i class="fas fa-coins"></i> Economy</a>
      <a href="/dashboard/<%= guild.id %>/shop" class="sidebar-link active"><i class="fas fa-store"></i> Shop</a>
      <div class="sidebar-section-label">Moderation</div>
      <a href="/dashboard/<%= guild.id %>/moderation" class="sidebar-link"><i class="fas fa-shield-halved"></i> Moderation</a>
      <a href="/dashboard/<%= guild.id %>/automod" class="sidebar-link"><i class="fas fa-robot"></i> Auto-Mod</a>
      <div class="sidebar-section-label">Stats</div>
      <a href="/dashboard/<%= guild.id %>/analytics" class="sidebar-link"><i class="fas fa-chart-line"></i> Analytics</a>
      <a href="/global-leaderboard" class="sidebar-link"><i class="fas fa-globe"></i> Global Leaderboard</a>
    </nav>
    <div class="sidebar-footer"><a href="/logout" class="sidebar-link danger"><i class="fas fa-sign-out-alt"></i> Logout</a></div>
  </aside>
  <div class="sidebar-overlay" id="sidebarOverlay"></div>
  <div class="main-wrapper">
    <header class="topbar">
      <div class="topbar-left">
        <button class="mobile-menu-btn" id="mobileMenuBtn"><i class="fas fa-bars"></i></button>
        <div><div class="topbar-title">Shop Manager</div><div class="topbar-subtitle"><%= guild.name %></div></div>
      </div>
      <div class="topbar-right">
        <button class="icon-btn" id="themeToggle"><i class="fas fa-moon"></i></button>
        <div class="topbar-user">
          <img src="https://cdn.discordapp.com/avatars/<%= user.id %>/<%= user.avatar %>.png" alt="Avatar" onerror="this.src='https://cdn.discordapp.com/embed/avatars/0.png'">
          <span class="topbar-user-name"><%= user.username %></span>
        </div>
      </div>
    </header>
    <main class="content">
      <div class="page-header">
        <h1><i class="fas fa-store" style="color:var(--brand);margin-right:8px"></i>Shop Manager</h1>
        <p>Manage economy shop items for <strong><%= guild.name %></strong></p>
      </div>
      <div class="stats-row">
        <div class="stat-card">
          <div class="stat-card-header"><span class="stat-card-label">Shop Items</span><div class="stat-card-icon blue"><i class="fas fa-box"></i></div></div>
          <div class="stat-card-value"><%= shopItems.length %></div>
          <div class="stat-card-change"><i class="fas fa-store"></i> In shop</div>
        </div>
        <div class="stat-card">
          <div class="stat-card-header"><span class="stat-card-label">Top Balance</span><div class="stat-card-icon yellow"><i class="fas fa-crown"></i></div></div>
          <div class="stat-card-value"><%= leaderboard.length > 0 ? formatNumber(leaderboard[0].balance || 0) : 0 %></div>
          <div class="stat-card-change"><i class="fas fa-coins"></i> <% if(leaderboard[0]) { %><%= leaderboard[0].username %><% } else { %>Nobody<% } %></div>
        </div>
        <div class="stat-card">
          <div class="stat-card-header"><span class="stat-card-label">Economy Users</span><div class="stat-card-icon purple"><i class="fas fa-users"></i></div></div>
          <div class="stat-card-value"><%= leaderboard.length %></div>
          <div class="stat-card-change"><i class="fas fa-users"></i> Tracked</div>
        </div>
        <div class="stat-card">
          <div class="stat-card-header"><span class="stat-card-label">Cheapest Item</span><div class="stat-card-icon green"><i class="fas fa-tag"></i></div></div>
          <div class="stat-card-value"><% if(shopItems.length > 0) { %><%= formatNumber(Math.min(...shopItems.map(i=>i.price))) %><% } else { %>—<% } %></div>
          <div class="stat-card-change"><i class="fas fa-coins"></i> Coins</div>
        </div>
      </div>
      <div class="card">
        <div class="card-header"><div class="card-title"><i class="fas fa-bars"></i> Manage Shop</div></div>
        <div class="tabs">
          <button class="tab-btn active" data-tab="items"><i class="fas fa-box"></i> Shop Items</button>
          <button class="tab-btn" data-tab="add"><i class="fas fa-plus"></i> Add Item</button>
          <button class="tab-btn" data-tab="balances"><i class="fas fa-coins"></i> Manage Balances</button>
        </div>
        <div class="tab-panel active" id="tab-items">
          <% if (shopItems && shopItems.length > 0) { %>
            <div class="shop-grid">
              <% shopItems.forEach(item => { %>
                <div class="shop-item-card">
                  <div class="shop-item-header">
                    <span class="badge badge-info"><%= item.type %></span>
                    <button class="btn btn-danger btn-sm" onclick="deleteItem('<%= item.id %>')"><i class="fas fa-trash"></i></button>
                  </div>
                  <h4 class="shop-item-name"><%= item.name %></h4>
                  <p class="shop-item-desc"><%= item.description || 'No description' %></p>
                  <div class="shop-item-price"><i class="fas fa-coins"></i> <%= formatNumber(item.price) %></div>
                  <div style="font-size:11px;color:var(--text-2);margin-top:4px">ID: <code><%= item.id %></code></div>
                </div>
              <% }); %>
            </div>
          <% } else { %>
            <div class="table-empty"><i class="fas fa-store"></i> No shop items yet. Add some in the "Add Item" tab!</div>
          <% } %>
        </div>
        <div class="tab-panel" id="tab-add">
          <form id="addItemForm">
            <div class="form-row">
              <div class="form-group">
                <label class="form-label">Item Name</label>
                <input type="text" class="form-control" name="name" placeholder="VIP Role" required>
              </div>
              <div class="form-group">
                <label class="form-label">Price (coins)</label>
                <input type="number" class="form-control" name="price" placeholder="10000" min="1" required>
              </div>
            </div>
            <div class="form-row">
              <div class="form-group">
                <label class="form-label">Type</label>
                <select class="form-control" name="type">
                  <option value="role">Role</option>
                  <option value="badge">Badge</option>
                  <option value="item">Item</option>
                </select>
              </div>
              <div class="form-group">
                <label class="form-label">Item ID</label>
                <input type="text" class="form-control" name="id" placeholder="vip_role" required>
              </div>
            </div>
            <div class="form-group">
              <label class="form-label">Description</label>
              <textarea class="form-control" name="description" placeholder="Describe this item..." rows="3"></textarea>
            </div>
            <button type="submit" class="btn btn-primary btn-lg"><i class="fas fa-plus"></i> Add Item</button>
          </form>
        </div>
        <div class="tab-panel" id="tab-balances">
          <div class="card" style="background:var(--bg-card-2);border:1px solid var(--border);margin-bottom:20px">
            <div class="card-header"><div class="card-title"><i class="fas fa-coins"></i> Adjust User Balance</div></div>
            <form id="balanceForm">
              <div class="form-row">
                <div class="form-group">
                  <label class="form-label">User ID</label>
                  <input type="text" class="form-control" name="userId" placeholder="Enter Discord user ID" required>
                </div>
                <div class="form-group">
                  <label class="form-label">Amount</label>
                  <input type="number" class="form-control" name="amount" placeholder="1000" required>
                </div>
                <div class="form-group">
                  <label class="form-label">Action</label>
                  <select class="form-control" name="action">
                    <option value="add">Add Coins</option>
                    <option value="remove">Remove Coins</option>
                    <option value="set">Set Balance</option>
                  </select>
                </div>
              </div>
              <button type="submit" class="btn btn-primary"><i class="fas fa-check"></i> Apply</button>
            </form>
          </div>
          <div class="table-wrapper">
            <table>
              <thead><tr><th>Rank</th><th>User</th><th>Balance</th><th>Level</th></tr></thead>
              <tbody>
                <% if (leaderboard && leaderboard.length > 0) { %>
                  <% leaderboard.forEach((u, i) => { %>
                    <tr>
                      <td><span class="rank-badge <%= i===0?'gold':i===1?'silver':i===2?'bronze':'normal' %>"><%= i+1 %></span></td>
                      <td><%= u.username || 'Unknown' %></td>
                      <td><strong style="color:var(--green)"><i class="fas fa-coins" style="font-size:11px;margin-right:3px"></i><%= formatNumber(u.balance || 0) %></strong></td>
                      <td><span class="badge badge-info">Lv <%= u.level || 0 %></span></td>
                    </tr>
                  <% }); %>
                <% } else { %>
                  <tr><td colspan="4" class="table-empty"><i class="fas fa-coins"></i> No economy data</td></tr>
                <% } %>
              </tbody>
            </table>
          </div>
        </div>
      </div>
    </main>
  </div>
</div>
<div class="toast-container" id="toasts"></div>
<script>
const guildId = '<%= guild.id %>';
const saved = localStorage.getItem('theme') || 'dark';
document.documentElement.setAttribute('data-theme', saved);
const themeBtn = document.getElementById('themeToggle');
themeBtn.innerHTML = saved === 'dark' ? '<i class="fas fa-moon"></i>' : '<i class="fas fa-sun"></i>';
themeBtn.addEventListener('click', () => {
  const cur = document.documentElement.getAttribute('data-theme');
  const next = cur === 'dark' ? 'light' : 'dark';
  document.documentElement.setAttribute('data-theme', next);
  localStorage.setItem('theme', next);
  themeBtn.innerHTML = next === 'dark' ? '<i class="fas fa-moon"></i>' : '<i class="fas fa-sun"></i>';
});
const sidebar = document.getElementById('sidebar');
const overlay = document.getElementById('sidebarOverlay');
document.getElementById('mobileMenuBtn').addEventListener('click', () => { sidebar.classList.toggle('open'); overlay.classList.toggle('active'); });
overlay.addEventListener('click', () => { sidebar.classList.remove('open'); overlay.classList.remove('active'); });
function toast(msg, type = 'success') {
  const c = document.getElementById('toasts');
  const t = document.createElement('div');
  t.className = `toast toast-${type}`;
  const icons = { success: 'fa-check-circle', error: 'fa-xmark-circle' };
  t.innerHTML = `<i class="fas ${icons[type] || 'fa-check-circle'}"></i> ${msg}`;
  c.appendChild(t);
  setTimeout(() => t.remove(), 3200);
}
document.querySelectorAll('.tab-btn').forEach(btn => {
  btn.addEventListener('click', () => {
    document.querySelectorAll('.tab-btn').forEach(b => b.classList.remove('active'));
    document.querySelectorAll('.tab-panel').forEach(p => p.classList.remove('active'));
    btn.classList.add('active');
    document.getElementById('tab-' + btn.dataset.tab).classList.add('active');
  });
});
document.getElementById('addItemForm').addEventListener('submit', async e => {
  e.preventDefault();
  const data = Object.fromEntries(new FormData(e.target));
  data.price = parseInt(data.price);
  try {
    const r = await fetch(`/api/${guildId}/shop/items`, { method: 'POST', headers: { 'Content-Type': 'application/json' }, body: JSON.stringify(data) });
    if (r.ok) { toast('Item added!', 'success'); setTimeout(() => location.reload(), 900); }
    else toast('Failed to add item', 'error');
  } catch(err) { toast('Error: ' + err.message, 'error'); }
});
async function deleteItem(itemId) {
  if (!confirm('Delete this item?')) return;
  try {
    const r = await fetch(`/api/${guildId}/shop/items/${itemId}`, { method: 'DELETE' });
    if (r.ok) { toast('Item deleted!', 'success'); setTimeout(() => location.reload(), 900); }
    else toast('Failed to delete', 'error');
  } catch(err) { toast('Error: ' + err.message, 'error'); }
}
document.getElementById('balanceForm').addEventListener('submit', async e => {
  e.preventDefault();
  const data = Object.fromEntries(new FormData(e.target));
  data.amount = parseInt(data.amount);
  try {
    const r = await fetch(`/api/${guildId}/shop/balance`, { method: 'POST', headers: { 'Content-Type': 'application/json' }, body: JSON.stringify(data) });
    if (r.ok) { toast('Balance updated!', 'success'); setTimeout(() => location.reload(), 900); }
    else toast('Failed to update balance', 'error');
  } catch(err) { toast('Error: ' + err.message, 'error'); }
});
</script>
</body>
</html>