<!DOCTYPE html>
<html lang="en" data-theme="dark">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title><%= guild.name %> — Analytics</title>
    <link rel="stylesheet" href="/style.css">
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.5.0/css/all.min.css" crossorigin="anonymous">
    <script src="https://cdn.jsdelivr.net/npm/chart.js@4.4.0/dist/chart.umd.min.js"></script>
</head>
<body>
<div class="app-layout">
    <aside class="sidebar" id="sidebar">
        <div class="sidebar-header">
            <a href="/dashboard" class="sidebar-back"><i class="fas fa-arrow-left"></i> All Servers</a>
            <div class="sidebar-guild">
                <% if (guild.icon) { %>
                    <img class="sidebar-guild-icon" src="https://cdn.discordapp.com/icons/<%= guild.id %>/<%= guild.icon %>.png" alt="<%= guild.name %>">
                <% } else { %>
                    <div class="sidebar-guild-icon-default"><%= guild.name.charAt(0) %></div>
                <% } %>
                <div class="sidebar-guild-info"><h3><%= guild.name %></h3><span><%= guild.memberCount %> members</span></div>
            </div>
        </div>
        <nav class="sidebar-nav">
            <div class="sidebar-section-label">Server</div>
            <a href="/dashboard/<%= guild.id %>" class="sidebar-link"><i class="fas fa-cog"></i> Settings</a>
            <a href="/dashboard/<%= guild.id %>/economy" class="sidebar-link"><i class="fas fa-coins"></i> Economy</a>
            <a href="/dashboard/<%= guild.id %>/shop" class="sidebar-link"><i class="fas fa-store"></i> Shop</a>
            <a href="/dashboard/<%= guild.id %>/commands" class="sidebar-link"><i class="fas fa-terminal"></i> Commands</a>
            <div class="sidebar-section-label">Moderation</div>
            <a href="/dashboard/<%= guild.id %>/moderation" class="sidebar-link"><i class="fas fa-shield-halved"></i> Moderation</a>
            <a href="/dashboard/<%= guild.id %>/automod" class="sidebar-link"><i class="fas fa-robot"></i> Auto-Mod</a>
            <div class="sidebar-section-label">Stats</div>
            <a href="/dashboard/<%= guild.id %>/analytics" class="sidebar-link active"><i class="fas fa-chart-line"></i> Analytics</a>
            <a href="/global-leaderboard" class="sidebar-link"><i class="fas fa-globe"></i> Global Leaderboard</a>
        </nav>
        <div class="sidebar-footer"><a href="/logout" class="sidebar-link danger"><i class="fas fa-sign-out-alt"></i> Logout</a></div>
    </aside>
    <div class="sidebar-overlay" id="sidebarOverlay"></div>

    <div class="main-wrapper">
        <header class="topbar">
            <div class="topbar-left">
                <button class="mobile-menu-btn" id="mobileMenuBtn"><i class="fas fa-bars"></i></button>
                <div><div class="topbar-title">Analytics</div><div class="topbar-subtitle"><%= guild.name %></div></div>
            </div>
            <div class="topbar-right">
                <button class="icon-btn" id="themeToggle"><i class="fas fa-moon"></i></button>
                <div class="topbar-user">
                    <img src="https://cdn.discordapp.com/avatars/<%= user.id %>/<%= user.avatar %>.png" alt="Avatar" onerror="this.src='https://cdn.discordapp.com/embed/avatars/0.png'">
                    <span class="topbar-user-name"><%= user.username %></span>
                </div>
            </div>
        </header>

        <main class="content">
            <div class="page-header">
                <h1><i class="fas fa-chart-line" style="color:var(--brand);margin-right:8px"></i>Server Analytics</h1>
                <p>Activity overview for <strong><%= guild.name %></strong></p>
            </div>

            <div class="stats-row">
                <div class="stat-card">
                    <div class="stat-card-header"><span class="stat-card-label">Messages Today</span><div class="stat-card-icon blue"><i class="fas fa-message"></i></div></div>
                    <div class="stat-card-value"><%= analytics.overview.messages %></div>
                    <div class="stat-card-change"><i class="fas fa-arrow-trend-up"></i> Today</div>
                </div>
                <div class="stat-card">
                    <div class="stat-card-header"><span class="stat-card-label">Commands Used</span><div class="stat-card-icon purple"><i class="fas fa-terminal"></i></div></div>
                    <div class="stat-card-value"><%= analytics.overview.commands %></div>
                    <div class="stat-card-change"><i class="fas fa-terminal"></i> Total today</div>
                </div>
                <div class="stat-card">
                    <div class="stat-card-header"><span class="stat-card-label">Members</span><div class="stat-card-icon orange"><i class="fas fa-users"></i></div></div>
                    <div class="stat-card-value"><%= analytics.overview.members %></div>
                    <div class="stat-card-change"><i class="fas fa-server"></i> In server</div>
                </div>
                <div class="stat-card">
                    <div class="stat-card-header"><span class="stat-card-label">Engagement</span><div class="stat-card-icon yellow"><i class="fas fa-fire"></i></div></div>
                    <div class="stat-card-value"><%= Math.round(analytics.engagement.score) %>%</div>
                    <div class="stat-card-change"><i class="fas fa-chart-pie"></i> Score</div>
                </div>
            </div>

            <div style="display:grid;grid-template-columns:1fr 1fr;gap:20px;margin-bottom:20px">
                <div class="card">
                    <div class="card-header"><div class="card-title"><i class="fas fa-chart-bar"></i> Top Commands</div></div>
                    <canvas id="cmdChart" height="200"></canvas>
                </div>
                <div class="card">
                    <div class="card-header"><div class="card-title"><i class="fas fa-chart-line"></i> Activity Trend</div></div>
                    <canvas id="activityChart" height="200"></canvas>
                </div>
            </div>

            <div class="card">
                <div class="card-header"><div class="card-title"><i class="fas fa-list-ol"></i> Top Commands Breakdown</div></div>
                <div class="table-wrapper">
                    <table>
                        <thead><tr><th>#</th><th>Command</th><th>Total Uses</th><th>Success</th><th>Failed</th><th>Rate</th></tr></thead>
                        <tbody>
                            <% if (analytics.topCommands && analytics.topCommands.length > 0) { %>
                                <% analytics.topCommands.forEach((cmd, i) => { %>
                                    <% const rate = cmd.count > 0 ? Math.round((cmd.success / cmd.count) * 100) : 0; %>
                                    <tr>
                                        <td><span class="rank-badge <%= i===0?'gold':i===1?'silver':i===2?'bronze':'normal' %>"><%= i+1 %></span></td>
                                        <td><code><%= cmd.command %></code></td>
                                        <td><strong><%= cmd.count %></strong></td>
                                        <td><span class="badge badge-success"><i class="fas fa-check"></i> <%= cmd.success %></span></td>
                                        <td><span class="badge badge-danger"><i class="fas fa-xmark"></i> <%= cmd.failed %></span></td>
                                        <td><div style="display:flex;align-items:center;gap:8px"><div style="flex:1;height:6px;background:var(--border);border-radius:3px;overflow:hidden"><div style="height:100%;width:<%= rate %>%;background:var(--green);border-radius:3px"></div></div><span style="font-size:12px;color:var(--text-2)"><%= rate %>%</span></div></td>
                                    </tr>
                                <% }); %>
                            <% } else { %>
                                <tr><td colspan="6" class="table-empty"><i class="fas fa-terminal"></i> No command data yet</td></tr>
                            <% } %>
                        </tbody>
                    </table>
                </div>
            </div>
        </main>
    </div>
</div>

<script>
const saved = localStorage.getItem('theme') || 'dark';
document.documentElement.setAttribute('data-theme', saved);
const themeBtn = document.getElementById('themeToggle');
themeBtn.innerHTML = saved === 'dark' ? '<i class="fas fa-moon"></i>' : '<i class="fas fa-sun"></i>';
themeBtn.addEventListener('click', () => {
    const cur = document.documentElement.getAttribute('data-theme');
    const next = cur === 'dark' ? 'light' : 'dark';
    document.documentElement.setAttribute('data-theme', next);
    localStorage.setItem('theme', next);
    themeBtn.innerHTML = next === 'dark' ? '<i class="fas fa-moon"></i>' : '<i class="fas fa-sun"></i>';
});
const sidebar = document.getElementById('sidebar');
const overlay = document.getElementById('sidebarOverlay');
document.getElementById('mobileMenuBtn').addEventListener('click', () => { sidebar.classList.toggle('open'); overlay.classList.toggle('active'); });
overlay.addEventListener('click', () => { sidebar.classList.remove('open'); overlay.classList.remove('active'); });

const topCmds = <%- JSON.stringify(analytics.topCommands || []) %>;
const dailyAct = <%- JSON.stringify(analytics.dailyActivity || {}) %>;
const isDark = document.documentElement.getAttribute('data-theme') === 'dark';
const gridColor = isDark ? 'rgba(255,255,255,0.06)' : 'rgba(0,0,0,0.06)';
const textColor = isDark ? '#94a3b8' : '#64748b';
Chart.defaults.color = textColor;
Chart.defaults.borderColor = gridColor;
new Chart(document.getElementById('cmdChart'), {
    type: 'bar',
    data: {
        labels: topCmds.slice(0,10).map(c => c.command),
        datasets: [{
            label: 'Uses',
            data: topCmds.slice(0,10).map(c => c.count),
            backgroundColor: '#5865F2cc',
            borderColor: '#5865F2',
            borderWidth: 1,
            borderRadius: 6
        }]
    },
    options: { plugins: { legend: { display: false } }, scales: { y: { beginAtZero: true } }, responsive: true, maintainAspectRatio: true }
});
const actEntries = Object.entries(dailyAct).sort(([a],[b]) => a.localeCompare(b)).slice(-14);
new Chart(document.getElementById('activityChart'), {
    type: 'line',
    data: {
        labels: actEntries.map(([d]) => d),
        datasets: [{
            label: 'Activity',
            data: actEntries.map(([,v]) => v),
            borderColor: '#57F287',
            backgroundColor: 'rgba(87,242,135,0.12)',
            borderWidth: 2,
            fill: true,
            tension: 0.4,
            pointBackgroundColor: '#57F287',
            pointRadius: 3
        }]
    },
    options: { plugins: { legend: { display: false } }, scales: { y: { beginAtZero: true } }, responsive: true, maintainAspectRatio: true }
});
</script>
</body>
</html>
