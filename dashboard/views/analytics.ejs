<!DOCTYPE html>
<html lang="en" data-theme="dark">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title><%= guild.name %> — Analytics</title>
    <link rel="stylesheet" href="/style.css">
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.5.0/css/all.min.css" crossorigin="anonymous">
    <script src="https://cdn.jsdelivr.net/npm/chart.js@4.4.0/dist/chart.umd.min.js"></script>
</head>
<body>
<%
    const messagesToday = analytics.overview.messages || 0;
    const commandsToday = analytics.overview.commands || 0;
    const engagementScore = Math.round(analytics.engagement.score || 0);
    const topCommand = analytics.topCommands && analytics.topCommands.length > 0 ? analytics.topCommands[0] : null;
%>
<div class="app-layout">
    <%- include('partials/dashboard-sidebar', { guild, currentPath }) %>

    <div class="main-wrapper">
        <%- include('partials/dashboard-topbar', { guild, user, topbarTitle: 'Analytics' }) %>

        <main class="content">
            <div class="page-header">
                <div class="page-header-badges">
                    <div class="page-header-badge"><i class="fas fa-message"></i> <%= messagesToday %> messages today</div>
                    <div class="page-header-badge"><i class="fas fa-terminal"></i> <%= commandsToday %> commands used</div>
                    <div class="page-header-badge"><i class="fas fa-fire"></i> <%= engagementScore %>% engagement</div>
                </div>
                <h1>Read the server’s usage patterns at a glance</h1>
                <p>Analytics turns recent command usage, message flow, and engagement trends for <strong><%= guild.name %></strong> into a fast operational view instead of a raw stat dump.</p>
            </div>

            <div class="dashboard-hero-grid">
                <section class="dashboard-hero-card">
                    <h2>Usage pulse</h2>
                    <p>See what members are doing today, which commands drive the most activity, and whether the server is trending up or cooling off.</p>
                    <div class="dashboard-hero-pills">
                        <div class="dashboard-hero-pill">
                            <strong><%= messagesToday %></strong>
                            <span>Messages tracked today</span>
                        </div>
                        <div class="dashboard-hero-pill">
                            <strong><%= commandsToday %></strong>
                            <span>Command executions today</span>
                        </div>
                        <div class="dashboard-hero-pill">
                            <strong><%= topCommand ? topCommand.command : 'None' %></strong>
                            <span>Most used command right now</span>
                        </div>
                    </div>
                </section>

                <div class="dashboard-hero-side-stack">
                    <section class="dashboard-hero-card">
                        <h3>Quick read</h3>
                        <div class="dashboard-glance-list">
                            <div class="dashboard-glance-item">
                                <strong><%= engagementScore %>% engagement score</strong>
                                <span>Use this as a short-hand health check before you drill into tables and trend charts.</span>
                            </div>
                            <div class="dashboard-glance-item">
                                <strong><%= analytics.overview.members %> members in scope</strong>
                                <span>The member count anchors the message and command numbers to current server size.</span>
                            </div>
                        </div>
                    </section>
                </div>
            </div>

            <div class="stats-row">
                <div class="stat-card">
                    <div class="stat-card-header"><span class="stat-card-label">Messages Today</span><div class="stat-card-icon blue"><i class="fas fa-message"></i></div></div>
                    <div class="stat-card-value"><%= analytics.overview.messages %></div>
                    <div class="stat-card-change"><i class="fas fa-arrow-trend-up"></i> Today</div>
                </div>
                <div class="stat-card">
                    <div class="stat-card-header"><span class="stat-card-label">Commands Used</span><div class="stat-card-icon purple"><i class="fas fa-terminal"></i></div></div>
                    <div class="stat-card-value"><%= analytics.overview.commands %></div>
                    <div class="stat-card-change"><i class="fas fa-terminal"></i> Total today</div>
                </div>
                <div class="stat-card">
                    <div class="stat-card-header"><span class="stat-card-label">Members</span><div class="stat-card-icon orange"><i class="fas fa-users"></i></div></div>
                    <div class="stat-card-value"><%= analytics.overview.members %></div>
                    <div class="stat-card-change"><i class="fas fa-server"></i> In server</div>
                </div>
                <div class="stat-card">
                    <div class="stat-card-header"><span class="stat-card-label">Engagement</span><div class="stat-card-icon yellow"><i class="fas fa-fire"></i></div></div>
                    <div class="stat-card-value"><%= Math.round(analytics.engagement.score) %>%</div>
                    <div class="stat-card-change"><i class="fas fa-chart-pie"></i> Score</div>
                </div>
            </div>

            <div class="dashboard-split-grid">
                <div class="card chart-card">
                    <div class="card-header"><div class="card-title"><i class="fas fa-chart-bar"></i> Top Commands</div></div>
                    <canvas id="cmdChart" height="200"></canvas>
                </div>
                <div class="card chart-card">
                    <div class="card-header"><div class="card-title"><i class="fas fa-chart-line"></i> Activity Trend</div></div>
                    <canvas id="activityChart" height="200"></canvas>
                </div>
            </div>

            <div class="card">
                <div class="card-header"><div class="card-title"><i class="fas fa-list-ol"></i> Top Commands Breakdown</div></div>
                <div class="table-wrapper">
                    <table>
                        <thead><tr><th>#</th><th>Command</th><th>Total Uses</th><th>Success</th><th>Failed</th><th>Rate</th></tr></thead>
                        <tbody>
                            <% if (analytics.topCommands && analytics.topCommands.length > 0) { %>
                                <% analytics.topCommands.forEach((cmd, i) => { %>
                                    <% const rate = cmd.count > 0 ? Math.round((cmd.success / cmd.count) * 100) : 0; %>
                                    <tr>
                                        <td><span class="rank-badge <%= i===0?'gold':i===1?'silver':i===2?'bronze':'normal' %>"><%= i+1 %></span></td>
                                        <td><code><%= cmd.command %></code></td>
                                        <td><strong><%= cmd.count %></strong></td>
                                        <td><span class="badge badge-success"><i class="fas fa-check"></i> <%= cmd.success %></span></td>
                                        <td><span class="badge badge-danger"><i class="fas fa-xmark"></i> <%= cmd.failed %></span></td>
                                        <td>
                                            <div class="analytics-rate-row">
                                                <div class="analytics-rate-track">
                                                    <div class="analytics-rate-fill" data-rate="<%= rate %>"></div>
                                                </div>
                                                <span class="analytics-rate-label"><%= rate %>%</span>
                                            </div>
                                        </td>
                                    </tr>
                                <% }); %>
                            <% } else { %>
                                <tr><td colspan="6" class="table-empty"><i class="fas fa-terminal"></i> No command data yet</td></tr>
                            <% } %>
                        </tbody>
                    </table>
                </div>
            </div>

            <div class="dashboard-split-grid" style="margin-top:20px">
                <div class="card">
                    <div class="card-header"><div class="card-title"><i class="fas fa-user-pen"></i> Most Messages Sent</div></div>
                    <div class="table-wrapper">
                        <table>
                            <thead><tr><th>#</th><th>User</th><th>Messages</th><th>Last Message</th></tr></thead>
                            <tbody>
                                <% if (topMessageUsers && topMessageUsers.length > 0) { %>
                                    <% topMessageUsers.forEach((entry, i) => { %>
                                        <tr>
                                            <td><span class="rank-badge <%= i===0?'gold':i===1?'silver':i===2?'bronze':'normal' %>"><%= i + 1 %></span></td>
                                            <td><strong><%= entry.username || `Unknown (${entry.userId})` %></strong><div class="form-hint">ID: <%= entry.userId %></div></td>
                                            <td><span class="badge badge-green"><i class="fas fa-message"></i> <%= entry.messages || 0 %></span></td>
                                            <td><%= entry.lastMessage ? new Date(entry.lastMessage).toLocaleString() : 'Never' %></td>
                                        </tr>
                                    <% }); %>
                                <% } else { %>
                                    <tr><td colspan="4" class="table-empty"><i class="fas fa-user-pen"></i> No message activity tracked yet</td></tr>
                                <% } %>
                            </tbody>
                        </table>
                    </div>
                </div>

                <div class="card">
                    <div class="card-header"><div class="card-title"><i class="fas fa-hashtag"></i> Most Active Channels</div></div>
                    <div class="table-wrapper">
                        <table>
                            <thead><tr><th>#</th><th>Channel</th><th>Messages</th></tr></thead>
                            <tbody>
                                <% if (topMessageChannels && topMessageChannels.length > 0) { %>
                                    <% topMessageChannels.forEach((entry, i) => { %>
                                        <tr>
                                            <td><span class="rank-badge <%= i===0?'gold':i===1?'silver':i===2?'bronze':'normal' %>"><%= i + 1 %></span></td>
                                            <td><strong>#<%= entry.channelName %></strong><div class="form-hint">ID: <%= entry.channelId %></div></td>
                                            <td><span class="badge badge-blue"><i class="fas fa-message"></i> <%= entry.messages || 0 %></span></td>
                                        </tr>
                                    <% }); %>
                                <% } else { %>
                                    <tr><td colspan="3" class="table-empty"><i class="fas fa-hashtag"></i> No channel activity tracked yet</td></tr>
                                <% } %>
                            </tbody>
                        </table>
                    </div>
                </div>
            </div>
        </main>
    </div>
</div>

<%- include('partials/dashboard-common-scripts') %>
<script type="application/json" id="analyticsTopCommands"><%- JSON.stringify(analytics.topCommands || []) %></script>
<script type="application/json" id="analyticsDailyActivity"><%- JSON.stringify(analytics.dailyActivity || {}) %></script>
<script>
const topCmds = JSON.parse(document.getElementById('analyticsTopCommands').textContent);
const dailyAct = JSON.parse(document.getElementById('analyticsDailyActivity').textContent);
const isDark = document.documentElement.getAttribute('data-theme') === 'dark';
const gridColor = isDark ? 'rgba(255,255,255,0.06)' : 'rgba(0,0,0,0.06)';
const textColor = isDark ? '#94a3b8' : '#64748b';

document.querySelectorAll('.analytics-rate-fill').forEach((element) => {
    const rate = Number(element.dataset.rate) || 0;
    element.style.width = Math.max(0, Math.min(100, rate)) + '%';
});

Chart.defaults.color = textColor;
Chart.defaults.borderColor = gridColor;
new Chart(document.getElementById('cmdChart'), {
    type: 'bar',
    data: {
        labels: topCmds.slice(0,10).map(c => c.command),
        datasets: [{
            label: 'Uses',
            data: topCmds.slice(0,10).map(c => c.count),
            backgroundColor: '#5865F2cc',
            borderColor: '#5865F2',
            borderWidth: 1,
            borderRadius: 6
        }]
    },
    options: { plugins: { legend: { display: false } }, scales: { y: { beginAtZero: true } }, responsive: true, maintainAspectRatio: true }
});
const actEntries = Object.entries(dailyAct).sort(([a],[b]) => a.localeCompare(b)).slice(-14);
new Chart(document.getElementById('activityChart'), {
    type: 'line',
    data: {
        labels: actEntries.map(([d]) => d),
        datasets: [{
            label: 'Activity',
            data: actEntries.map(([,v]) => v),
            borderColor: '#57F287',
            backgroundColor: 'rgba(87,242,135,0.12)',
            borderWidth: 2,
            fill: true,
            tension: 0.4,
            pointBackgroundColor: '#57F287',
            pointRadius: 3
        }]
    },
    options: { plugins: { legend: { display: false } }, scales: { y: { beginAtZero: true } }, responsive: true, maintainAspectRatio: true }
});
</script>
</body>
</html>
