<!DOCTYPE html>
<html lang="en" data-theme="dark">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title><%= guild.name %> — Activity Center</title>
  <link rel="stylesheet" href="/style.css">
  <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.5.0/css/all.min.css" crossorigin="anonymous">
</head>
<body>
<div class="app-layout">
  <%- include('partials/dashboard-sidebar', { guild, currentPath }) %>

  <div class="main-wrapper">
    <%- include('partials/dashboard-topbar', { guild, user, topbarTitle: 'Activity Center' }) %>

    <main class="content">
      <div class="page-header">
        <h1><i class="fas fa-clock-rotate-left" style="color:var(--brand);margin-right:8px"></i>Activity Center</h1>
        <p>Dashboard actions and server audit history for <strong><%= guild.name %></strong></p>
      </div>

      <% const topCategory = Object.entries(serverAuditStats.byCategory || {}).sort((a, b) => b[1] - a[1])[0]; %>
      <% const criticalCount = Object.entries(serverAuditStats.bySeverity || {}).reduce((sum, entry) => sum + (entry[0] === 'critical' ? entry[1] : 0), 0); %>
      <div class="stats-row">
        <div class="stat-card"><div class="stat-card-header"><span class="stat-card-label">Dashboard Actions</span><div class="stat-card-icon blue"><i class="fas fa-browser"></i></div></div><div class="stat-card-value"><%= dashboardAuditLogs.length %></div><div class="stat-card-change">Recent web dashboard events</div></div>
        <div class="stat-card"><div class="stat-card-header"><span class="stat-card-label">Server Audit Logs</span><div class="stat-card-icon purple"><i class="fas fa-scroll"></i></div></div><div class="stat-card-value"><%= serverAuditStats.total || 0 %></div><div class="stat-card-change">Last 14 days</div></div>
        <div class="stat-card"><div class="stat-card-header"><span class="stat-card-label">Top Category</span><div class="stat-card-icon orange"><i class="fas fa-layer-group"></i></div></div><div class="stat-card-value" style="font-size:20px"><%= topCategory ? topCategory[0] : 'None' %></div><div class="stat-card-change"><%= topCategory ? `${topCategory[1]} events` : 'No audit data' %></div></div>
        <div class="stat-card"><div class="stat-card-header"><span class="stat-card-label">Critical Events</span><div class="stat-card-icon red"><i class="fas fa-triangle-exclamation"></i></div></div><div class="stat-card-value"><%= criticalCount %></div><div class="stat-card-change">From server audit log</div></div>
      </div>

      <div class="card">
        <div class="card-header"><div><div class="card-title"><i class="fas fa-browser"></i> Dashboard Activity</div><div class="card-subtitle">Recent actions taken from the web dashboard</div></div></div>
        <div class="table-wrapper">
          <table>
            <thead><tr><th>Time</th><th>User</th><th>Action</th><th>Details</th></tr></thead>
            <tbody>
              <% if (dashboardAuditLogs.length > 0) { %>
                <% dashboardAuditLogs.forEach(entry => { %>
                  <tr>
                    <td><%= new Date(entry.timestamp).toLocaleString() %></td>
                    <td><%= entry.username || entry.userId || 'Unknown' %></td>
                    <td><strong><%= entry.action %></strong></td>
                    <td><code><%= JSON.stringify(entry.details || {}) %></code></td>
                  </tr>
                <% }) %>
              <% } else { %>
                <tr><td colspan="4" class="table-empty"><i class="fas fa-browser"></i> No dashboard activity recorded yet</td></tr>
              <% } %>
            </tbody>
          </table>
        </div>
      </div>

      <div class="card">
        <div class="card-header"><div><div class="card-title"><i class="fas fa-scroll"></i> Server Audit Feed</div><div class="card-subtitle">Bot audit log events recorded for this guild</div></div></div>
        <div class="table-wrapper">
          <table>
            <thead><tr><th>Time</th><th>Category</th><th>Action</th><th>Executor</th><th>Severity</th></tr></thead>
            <tbody>
              <% if (serverAuditLogs.length > 0) { %>
                <% serverAuditLogs.forEach(entry => { %>
                  <tr>
                    <td><%= entry.timestamp ? new Date(entry.timestamp).toLocaleString() : 'Unknown' %></td>
                    <td><%= entry.category || 'uncategorized' %></td>
                    <td><strong><%= entry.action || 'unknown' %></strong></td>
                    <td><%= entry.executor?.tag || entry.executor?.id || 'Unknown' %></td>
                    <td><span class="badge <%= entry.severity === 'critical' ? 'badge-red' : entry.severity === 'warn' ? 'badge-yellow' : 'badge-green' %>"><%= entry.severity || 'info' %></span></td>
                  </tr>
                <% }) %>
              <% } else { %>
                <tr><td colspan="5" class="table-empty"><i class="fas fa-scroll"></i> No server audit events found</td></tr>
              <% } %>
            </tbody>
          </table>
        </div>
      </div>
    </main>
  </div>
</div>

<%- include('partials/dashboard-common-scripts') %>
</body>
</html>