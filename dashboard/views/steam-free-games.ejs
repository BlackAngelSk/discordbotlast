<!DOCTYPE html>
<html lang="en" data-theme="dark">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title><%= guild.name %> — Steam Free Games</title>
    <link rel="stylesheet" href="/style.css">
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.5.0/css/all.min.css" crossorigin="anonymous">
</head>
<body>
<div class="app-layout">
    <%- include('partials/dashboard-sidebar', { guild, currentPath }) %>

    <div class="main-wrapper">
        <%- include('partials/dashboard-topbar', { guild, user, topbarTitle: 'Steam Free Games' }) %>

        <main class="content">
            <div class="page-header">
                <h1><i class="fab fa-steam" style="color:var(--brand);margin-right:8px"></i>Steam Free-To-Keep Alerts</h1>
                <p>Choose where to post newly detected <strong>free-to-keep Steam games</strong> for this server.</p>
                <% const activePromoCount = Number(typeof promoCount === 'undefined' ? 0 : promoCount) || 0; %>
                <% const sourceInfo = typeof sourceHealth === 'undefined' ? {} : (sourceHealth || {}); %>
                <% if (sourceInfo.steamDbFreeToKeepAvailable === false) { %>
                    <p style="margin-top:8px;color:#f4a318;background:rgba(244,163,24,0.12);border:1px solid rgba(244,163,24,0.35);border-radius:8px;padding:8px 10px;display:inline-block;max-width:100%">
                        <i class="fas fa-triangle-exclamation"></i>
                        SteamDB free-to-keep source is currently unavailable.
                        Showing fallback results instead.
                        <% if ((sourceInfo.steamStoreFreeToKeepFallbackCount || 0) > 0) { %>
                            Added <strong><%= sourceInfo.steamStoreFreeToKeepFallbackCount %></strong> fallback game<%= sourceInfo.steamStoreFreeToKeepFallbackCount === 1 ? '' : 's' %>.
                        <% } %>
                    </p>
                <% } %>
                <% if (activePromoCount > 0) { %>
                    <p style="margin-top:8px;color:var(--text-secondary)">
                        <i class="fas fa-info-circle"></i>
                        <strong><%= activePromoCount %></strong> limited-time Steam promo game<%= activePromoCount === 1 ? '' : 's' %> are listed on
                        <a href="/dashboard/<%= guild.id %>/steam-promos">Steam Promos</a>.
                    </p>
                <% } %>
            </div>

            <div class="stats-row">
                <div class="stat-card">
                    <div class="stat-card-header"><span class="stat-card-label">Status</span><div class="stat-card-icon <%= config?.channelId ? 'green' : 'yellow' %>"><i class="fas fa-bell"></i></div></div>
                    <div class="stat-card-value"><%= config?.channelId ? 'On' : 'Off' %></div>
                    <div class="stat-card-change"><i class="fas fa-gift"></i> New Steam giveaways only</div>
                </div>
                <div class="stat-card">
                    <div class="stat-card-header"><span class="stat-card-label">Alert Channel</span><div class="stat-card-icon blue"><i class="fas fa-hashtag"></i></div></div>
                    <div class="stat-card-value" style="font-size:1rem"><%= config?.channelId ? `#${guild.channels.cache.get(config.channelId)?.name || config.channelId}` : 'Not set' %></div>
                    <div class="stat-card-change"><i class="fas fa-message"></i> Destination channel</div>
                </div>
                <div class="stat-card">
                    <div class="stat-card-header"><span class="stat-card-label">Active Giveaways</span><div class="stat-card-icon purple"><i class="fab fa-steam"></i></div></div>
                    <div class="stat-card-value"><%= giveaways.length %></div>
                    <div class="stat-card-change"><i class="fas fa-store"></i> Current Steam offers</div>
                </div>
                <div class="stat-card">
                    <div class="stat-card-header"><span class="stat-card-label">Last Checked</span><div class="stat-card-icon orange"><i class="fas fa-clock"></i></div></div>
                    <div class="stat-card-value" style="font-size:1rem"><%= config?.lastCheckedAt ? 'Saved' : 'Waiting' %></div>
                    <div class="stat-card-change"><%= config?.lastCheckedAt ? new Date(config.lastCheckedAt).toLocaleString() : 'No checks yet' %></div>
                </div>
            </div>

            <div class="card" style="margin-bottom:20px">
                <div class="card-header">
                    <div>
                        <div class="card-title"><i class="fas fa-sliders"></i> Dashboard Setup</div>
                        <div class="card-subtitle">Pick a text channel, save it, and optionally send a test alert.</div>
                    </div>
                </div>

                <form id="steamFreeGamesForm">
                    <div class="form-row">
                        <div class="form-group">
                            <label class="form-label">Discord Channel</label>
                            <select name="channelId" class="form-control" required>
                                <option value="">Select channel</option>
                                <% channels.forEach(channel => { %>
                                    <option value="<%= channel.id %>" <%= config?.channelId === channel.id ? 'selected' : '' %>>#<%= channel.name %></option>
                                <% }) %>
                            </select>
                            <div class="form-hint">The bot will post newly detected Steam free-game alerts here.</div>
                        </div>
                    </div>

                    <div class="form-actions" style="justify-content:flex-start">
                        <button type="submit" class="btn btn-primary"><i class="fas fa-save"></i> Save Channel</button>
                        <button type="button" class="btn btn-secondary" id="refreshSteamSourcesBtn"><i class="fas fa-rotate"></i> Refresh Sources Now</button>
                        <button type="button" class="btn btn-secondary" id="testSteamFreeGamesBtn"><i class="fas fa-flask"></i> Send Test Alert</button>
                        <button type="button" class="btn btn-danger" id="clearSteamFreeGamesBtn"><i class="fas fa-trash"></i> Disable Alerts</button>
                    </div>
                </form>
            </div>

            <div class="card">
                <div class="card-header">
                    <div>
                        <div class="card-title"><i class="fas fa-list"></i> Current Giveaways</div>
                        <div class="card-subtitle">Preview of the Steam giveaways currently reported by the free-game feed.</div>
                    </div>
                </div>

                <% if (giveaways.length > 0) { %>
                    <div style="display:grid;grid-template-columns:repeat(auto-fit,minmax(260px,1fr));gap:16px">
                        <% giveaways.forEach(giveaway => { %>
                            <article class="card" style="margin:0;background:var(--bg-card-2)">
                                <% if (giveaway.imageUrl) { %>
                                    <img src="<%= giveaway.imageUrl %>" alt="<%= giveaway.title %>" style="width:100%;aspect-ratio:16/9;object-fit:cover;border-radius:12px;margin-bottom:12px">
                                <% } %>
                                <div class="card-title" style="margin-bottom:8px"><%= giveaway.title %></div>
                                <div class="form-hint" style="margin-bottom:10px">
                                    <% if (giveaway.worth) { %>
                                        Worth <%= giveaway.worth %>
                                    <% } else { %>
                                        Free right now
                                    <% } %>
                                    <% if (giveaway.endDate) { %>
                                        · Ends <%= new Date(giveaway.endDate).toLocaleString() %>
                                    <% } %>
                                </div>
                                <% if (giveaway.description) { %>
                                    <p style="margin:0 0 12px;color:var(--text-secondary)"><%= giveaway.description %></p>
                                <% } %>
                                <a href="<%= giveaway.url %>" target="_blank" rel="noopener noreferrer" class="btn btn-secondary btn-sm"><i class="fas fa-up-right-from-square"></i> Claim Offer</a>
                            </article>
                        <% }) %>
                    </div>
                <% } else { %>
                    <div class="table-empty"><i class="fab fa-steam"></i>No Steam giveaways are available right now.</div>
                <% } %>
            </div>
        </main>
    </div>
</div>

<%- include('partials/dashboard-common-scripts') %>
<script>
const guildId = '<%= guild.id %>';
const form = document.getElementById('steamFreeGamesForm');
const channelSelect = form.querySelector('select[name="channelId"]');
const saveButton = form.querySelector('button[type="submit"]');
const refreshButton = document.getElementById('refreshSteamSourcesBtn');
const testButton = document.getElementById('testSteamFreeGamesBtn');
const clearButton = document.getElementById('clearSteamFreeGamesBtn');

refreshButton.addEventListener('click', async () => {
    const original = refreshButton.innerHTML;
    refreshButton.disabled = true;
    refreshButton.innerHTML = '<span class="spinner"></span> Refreshing...';

    try {
        const response = await fetch(`/api/steam-free-games/${guildId}/refresh`, {
            method: 'POST',
            headers: { 'Content-Type': 'application/json' }
        });

        const result = await response.json();
        if (!response.ok || !result.success) {
            throw new Error(result.error || 'Failed to refresh Steam sources');
        }

        dashboardUI.showToast(result.message || 'Steam sources refreshed.', 'success');
        setTimeout(() => location.reload(), 700);
    } catch (error) {
        dashboardUI.showToast(error.message || 'Failed to refresh Steam sources.', 'error');
    } finally {
        refreshButton.disabled = false;
        refreshButton.innerHTML = original;
    }
});

form.addEventListener('submit', async (event) => {
    event.preventDefault();
    const original = saveButton.innerHTML;
    saveButton.disabled = true;
    saveButton.innerHTML = '<span class="spinner"></span> Saving...';

    try {
        const response = await fetch(`/api/steam-free-games/${guildId}`, {
            method: 'POST',
            headers: { 'Content-Type': 'application/json' },
            body: JSON.stringify({ channelId: channelSelect.value })
        });
        const result = await response.json();
        if (!response.ok || !result.success) {
            throw new Error(result.error || 'Failed to save Steam free game alert channel');
        }
        dashboardUI.showToast('Steam free game alert channel saved.', 'success');
        setTimeout(() => location.reload(), 600);
    } catch (error) {
        dashboardUI.showToast(error.message || 'Failed to save Steam free game alert channel.', 'error');
    } finally {
        saveButton.disabled = false;
        saveButton.innerHTML = original;
    }
});

testButton.addEventListener('click', async () => {
    const original = testButton.innerHTML;
    testButton.disabled = true;
    testButton.innerHTML = '<span class="spinner"></span> Sending...';

    try {
        const response = await fetch(`/api/steam-free-games/${guildId}/test`, {
            method: 'POST',
            headers: { 'Content-Type': 'application/json' },
            body: JSON.stringify({ channelId: channelSelect.value || null })
        });
        const result = await response.json();
        if (!response.ok || !result.success) {
            throw new Error(result.error || 'Failed to send Steam free game test alert');
        }
        dashboardUI.showToast(result.message || 'Steam free game test alert sent.', 'success');
    } catch (error) {
        dashboardUI.showToast(error.message || 'Failed to send Steam free game test alert.', 'error');
    } finally {
        testButton.disabled = false;
        testButton.innerHTML = original;
    }
});

clearButton.addEventListener('click', async () => {
    if (!confirm('Disable Steam free game alerts for this server?')) {
        return;
    }

    const original = clearButton.innerHTML;
    clearButton.disabled = true;
    clearButton.innerHTML = '<span class="spinner"></span> Removing...';

    try {
        const response = await fetch(`/api/steam-free-games/${guildId}`, {
            method: 'DELETE',
            headers: { 'Content-Type': 'application/json' }
        });
        const result = await response.json();
        if (!response.ok || !result.success) {
            throw new Error(result.error || 'Failed to disable Steam free game alerts');
        }
        dashboardUI.showToast('Steam free game alerts disabled.', 'success');
        setTimeout(() => location.reload(), 500);
    } catch (error) {
        dashboardUI.showToast(error.message || 'Failed to disable Steam free game alerts.', 'error');
    } finally {
        clearButton.disabled = false;
        clearButton.innerHTML = original;
    }
});
</script>
</body>
</html>