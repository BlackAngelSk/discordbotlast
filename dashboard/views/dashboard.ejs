<!DOCTYPE html>
<html lang="en" data-theme="dark">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>Select Server — Dashboard</title>
  <link rel="stylesheet" href="/style.css">
  <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.5.0/css/all.min.css" crossorigin="anonymous">
</head>
<body>
<%
  const manageableGuildCount = Array.isArray(guilds) ? guilds.length : 0;
  const ownerToolCount = isBotOwner ? 1 : 0;
  const totalCardCount = manageableGuildCount + ownerToolCount;
%>
<div class="server-picker">

  <!-- Navbar -->
  <nav class="landing-nav">
    <div class="container">
      <a href="/" class="landing-nav-brand">
        <div class="landing-nav-brand-icon"><i class="fas fa-robot" style="color:white;font-size:16px"></i></div>
        Discord Bot
      </a>
      <div class="landing-nav-links">
        <div class="theme-switcher" id="themeSwitcher">
          <button class="theme-switch-btn active" data-theme="dark" title="Dark mode"><i class="fas fa-moon"></i></button>
          <button class="theme-switch-btn" data-theme="light" title="Light mode"><i class="fas fa-sun"></i></button>
        </div>
        <div class="topbar-user">
          <img src="https://cdn.discordapp.com/avatars/<%= user.id %>/<%= user.avatar %>.png" alt="Avatar" onerror="this.src='https://cdn.discordapp.com/embed/avatars/0.png'">
          <span class="topbar-user-name"><%= user.username %></span>
        </div>
        <a href="/logout" class="btn btn-secondary btn-sm"><i class="fas fa-sign-out-alt"></i> Logout</a>
      </div>
    </div>
  </nav>

  <!-- Content -->
  <div class="server-picker-content">
    <div class="server-picker-hero">
      <div>
        <div class="server-picker-header">
          <div>
            <div class="page-header-badges">
              <div class="page-header-badge"><i class="fas fa-layer-group"></i> Unified dashboard shell</div>
              <div class="page-header-badge"><i class="fas fa-rocket"></i> Faster entry into setup pages</div>
            </div>
            <h1>Your Servers</h1>
            <p>Pick a server, jump into the right workspace, and move from overview to detailed configuration without digging through flat admin pages.</p>
          </div>
          <div class="server-picker-summary-text">
            <i class="fas fa-bolt"></i>
            <span><%= totalCardCount %> dashboard destinations ready</span>
          </div>
        </div>

        <div class="server-picker-overview">
          <div class="server-picker-stat">
            <div class="server-picker-stat-icon"><i class="fas fa-server"></i></div>
            <div>
              <div class="server-picker-stat-value"><%= manageableGuildCount %></div>
              <div class="server-picker-stat-label">Manageable servers</div>
            </div>
          </div>
          <div class="server-picker-stat">
            <div class="server-picker-stat-icon"><i class="fas fa-shield-halved"></i></div>
            <div>
              <div class="server-picker-stat-value"><%= ownerToolCount %></div>
              <div class="server-picker-stat-label">Owner-only pages</div>
            </div>
          </div>
          <div class="server-picker-stat server-picker-stat-wide">
            <div class="server-picker-stat-icon"><i class="fas fa-compass"></i></div>
            <div>
              <div class="server-picker-stat-value">Fast jump</div>
              <div class="server-picker-stat-label">Use search and filters below to narrow large server lists and land directly in the workspace you need.</div>
            </div>
          </div>
        </div>
      </div>

      <aside class="server-picker-sidecard">
        <h2><i class="fas fa-compass" style="color:var(--brand);margin-right:8px"></i>Dashboard Map</h2>
        <p>Most of the advanced tools now live inside each server dashboard. Start with Settings, then branch into the focused feature pages.</p>
        <div class="server-picker-map-grid">
          <div class="server-picker-map-item">
            <strong>Activity Center</strong>
            <span>Review audit events and recent dashboard actions.</span>
          </div>
          <div class="server-picker-map-item">
            <strong>Delegation</strong>
            <span>Grant dashboard access without handing out full admin.</span>
          </div>
          <div class="server-picker-map-item">
            <strong>Quick Tests</strong>
            <span>Run validation for welcome, leave, logs, and suggestions.</span>
          </div>
          <div class="server-picker-map-item">
            <strong>Community Editing</strong>
            <span>Maintain posted role and community messages in place.</span>
          </div>
        </div>
        <% if (isBotOwner) { %>
          <div class="form-hint">Bot owner tools live in <strong>Bot Owner Settings</strong>. Server tools stay inside each selected server.</div>
        <% } else { %>
          <div class="form-hint">Open a server card below to reach the full setup workspace.</div>
        <% } %>
      </aside>
    </div>

    <!-- Search -->
    <div class="server-picker-toolbar">
      <div class="search-input server-search-input">
        <i class="fas fa-search"></i>
        <input type="text" id="serverSearch" placeholder="Search servers or owner tools...">
      </div>
      <div class="server-picker-filters" role="tablist" aria-label="Server filters">
        <button type="button" class="server-filter-btn is-active" data-filter="all">All</button>
        <button type="button" class="server-filter-btn" data-filter="server">Servers</button>
        <% if (isBotOwner) { %>
          <button type="button" class="server-filter-btn" data-filter="owner">Owner Tools</button>
        <% } %>
      </div>
      <div class="server-picker-results" id="serverResultsLabel"><%= totalCardCount %> results</div>
    </div>

    <div class="server-picker-shortcuts">
      <div class="server-picker-shortcut"><i class="fas fa-keyboard"></i> Press <strong>/</strong> to focus search</div>
      <div class="server-picker-shortcut"><i class="fas fa-filter"></i> Filter between server dashboards and owner tools</div>
      <div class="server-picker-shortcut"><i class="fas fa-arrow-pointer"></i> Click any card to jump straight into configuration</div>
    </div>

    <div class="server-picker-section-header">
      <div>
        <h2>Available Dashboards</h2>
        <p>Pick where you want to work next.</p>
      </div>
    </div>

    <!-- Grid -->
    <div class="server-grid" id="serverGrid">
      <% if (isBotOwner) { %>
        <a href="/dashboard/owner" class="server-card" data-name="bot owner settings global owner" data-type="owner">
          <div class="server-card-icon-default" style="background:linear-gradient(135deg,var(--yellow),var(--orange));color:#111827">
            <i class="fas fa-crown"></i>
          </div>
          <div class="server-card-name">Bot Owner Settings</div>
          <div class="server-card-meta"><i class="fas fa-shield"></i> Global bot controls</div>
          <div class="server-card-footer">
            <span class="badge badge-yellow"><i class="fas fa-crown"></i> Owner tools</span>
            <span class="server-card-linktext">Open workspace</span>
          </div>
        </a>
      <% } %>
      <% if (guilds.length === 0) { %>
        <div class="no-servers-msg">
          <i class="fas fa-robot"></i>
          <h2>No servers found</h2>
          <p>Invite the bot to your server to manage it here.</p>
          <a href="https://discord.com/api/oauth2/authorize?client_id=<%= process.env.CLIENT_ID %>&permissions=8&scope=bot%20applications.commands" target="_blank" class="btn btn-primary">
            <i class="fas fa-plus"></i> Invite Bot
          </a>
        </div>
      <% } else { %>
        <% guilds.forEach(guild => { %>
          <a href="/dashboard/<%= guild.id %>" class="server-card" data-name="<%= guild.name.toLowerCase() %>" data-type="server">
            <% if (guild.icon) { %>
              <img class="server-card-icon" src="https://cdn.discordapp.com/icons/<%= guild.id %>/<%= guild.icon %>.png" alt="<%= guild.name %>" onerror="this.style.display='none';this.nextElementSibling.style.display='flex'">
              <div class="server-card-icon-default" style="display:none"><%= guild.name.charAt(0).toUpperCase() %></div>
            <% } else { %>
              <div class="server-card-icon-default"><%= guild.name.charAt(0).toUpperCase() %></div>
            <% } %>
            <div class="server-card-name"><%= guild.name %></div>
            <div class="server-card-meta"><i class="fas fa-arrow-right"></i> Manage server</div>
            <div style="margin-top:10px;font-size:12px;color:var(--text-2)">
              <span class="badge <%= Number(guild.setupScore || 0) >= 80 ? 'badge-green' : Number(guild.setupScore || 0) >= 40 ? 'badge-yellow' : 'badge-red' %>">
                <i class="fas fa-list-check"></i>
                Setup <%= Number(guild.setupScore || 0) %>%
              </span>
              <% if (Number(guild.setupTotalCount || 0) > 0) { %>
                <span style="margin-left:6px"><%= Number(guild.setupCompletedCount || 0) %>/<%= Number(guild.setupTotalCount || 0) %></span>
              <% } %>
            </div>
            <div class="server-card-footer">
              <span class="badge badge-brand"><i class="fas fa-sliders"></i> Settings + tools</span>
              <span class="server-card-linktext">Open workspace</span>
            </div>
          </a>
        <% }); %>
      <% } %>
    </div>

    <% if (totalCardCount > 0) { %>
      <div class="server-picker-empty" id="serverEmptyState" hidden>
        <i class="fas fa-magnifying-glass"></i>
        <h2>No dashboard matches</h2>
        <p>Try a different search term or switch filter tabs.</p>
      </div>
    <% } %>
  </div>

</div>

<script>
  (function() {
    var saved = localStorage.getItem('theme') || 'dark';
    function applyPickerTheme(theme) {
      document.documentElement.setAttribute('data-theme', theme);
      document.querySelectorAll('.theme-switch-btn').forEach(function(b){ b.classList.toggle('active', b.dataset.theme === theme); });
    }
    applyPickerTheme(saved);
    document.querySelectorAll('.theme-switch-btn').forEach(function(btn) {
      btn.addEventListener('click', function() { applyPickerTheme(btn.dataset.theme); localStorage.setItem('theme', btn.dataset.theme); });
    });
  })();

  const searchInput = document.getElementById('serverSearch');
  const cards = Array.from(document.querySelectorAll('.server-card'));
  const filterButtons = Array.from(document.querySelectorAll('.server-filter-btn'));
  const resultLabel = document.getElementById('serverResultsLabel');
  const emptyState = document.getElementById('serverEmptyState');
  let activeFilter = 'all';

  const applyServerFilters = () => {
    const query = (searchInput.value || '').trim().toLowerCase();
    let visibleCount = 0;

    cards.forEach(card => {
      const matchesSearch = (card.dataset.name || '').includes(query);
      const matchesType = activeFilter === 'all' || card.dataset.type === activeFilter;
      const visible = matchesSearch && matchesType;
      card.hidden = !visible;
      if (visible) visibleCount += 1;
    });

    resultLabel.textContent = `${visibleCount} result${visibleCount === 1 ? '' : 's'}`;
    if (emptyState) {
      emptyState.hidden = visibleCount !== 0;
    }
  };

  searchInput.addEventListener('input', applyServerFilters);

  filterButtons.forEach(button => {
    button.addEventListener('click', () => {
      activeFilter = button.dataset.filter || 'all';
      filterButtons.forEach(item => item.classList.toggle('is-active', item === button));
      applyServerFilters();
    });
  });

  document.addEventListener('keydown', (event) => {
    if (event.key === '/' && document.activeElement !== searchInput) {
      event.preventDefault();
      searchInput.focus();
      searchInput.select();
    }
  });

  applyServerFilters();
</script>
</body>
</html>
