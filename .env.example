# ================== DISCORD BOT CONFIGURATION ==================
# Get your bot token from the Discord Developer Portal: https://discord.com/developers/app

DISCORD_TOKEN=your_bot_token_here

# ================== DATABASE (Optional) ==================
# MongoDB connection string (leave empty to use JSON files)
# Get from: https://www.mongodb.com/cloud/atlas
MONGODB_URI=mongodb+srv://username:password@cluster.mongodb.net
MONGODB_DBNAME=discord-bot

# Force IPv4 DNS/network path (helps on some VPS/ISPs with TLS+SRV issues)
MONGODB_FORCE_IPV4=true

# Optional TLS options (Linux common path shown below)
# MONGODB_TLS_CA_FILE=/etc/ssl/certs/ca-certificates.crt
# MONGODB_TLS_INSECURE=false

# Optional connection tuning
# MONGODB_SERVER_SELECTION_TIMEOUT_MS=10000
# MONGODB_CONNECT_TIMEOUT_MS=10000

# ================== DASHBOARD (Optional) ==================
# Enable the dashboard
DASHBOARD_ENABLED=true

# Bot Owner ID (Your Discord User ID - bypasses all moderation)
BOT_OWNER_ID=your_discord_user_id_here

# Dashboard OAuth2 credentials (for login feature)
CLIENT_ID=your_client_id
CLIENT_SECRET=your_client_secret
DASHBOARD_PORT=3000
SESSION_SECRET=some_random_secret

# ================== AI FEATURES (Optional) ==================
# Google Gemini API (Get from https://ai.google.dev/)
# This enables /ai commands for AI-powered responses
GOOGLE_API_KEY=your_google_gemini_api_key_here
GEMINI_API_KEY=your_google_gemini_api_key_here

# =================== TELEGRAM BOT CONFIGURATION (Optional) ==================
# Get your bot token from the Telegram BotFather: https://t.me/BotFather
TELEGRAM_BOT_TOKEN =your_telegram_bot_token_here

# ================== FEATURES (Optional) ==================
ENABLE_MUSIC=true
ENABLE_ECONOMY=true
ENABLE_MODERATION=true
ENABLE_GAMES=true
ENABLE_ANALYTICS=true
ENABLE_AI=true

# ================== DEVELOPMENT SETTINGS (Optional) ==================
# IMPORTANT: keep values plain (no inline comments after value)
DEV_MODE=false